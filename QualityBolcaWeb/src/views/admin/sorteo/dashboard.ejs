<script>
/* ============================================================
   PALETAS DE COLORES
============================================================ */
const PALETTES = {
    blue:      ['#1a73e8','#4285f4','#669df6','#8ab4f8','#c5d9fb','#e8f0fe'],
    green:     ['#34a853','#5bb974','#7dcf8e','#a8e6b8','#c8f0d0','#e6f9ec'],
    red:       ['#ea4335','#f06b62','#f28b82','#fcb9b4','#fde0dc','#fff5f5'],
    purple:    ['#9334e6','#a852f4','#bd7af6','#d4a8fb','#ead5fd','#f7eeff'],
    orange:    ['#fa7b17','#fb8c3c','#fba75a','#fcc585','#fde2b8','#fff5e6'],
    teal:      ['#007b5e','#00a07b','#00c49a','#33d4b1','#66e2c8','#99f0e0'],
    multi:     ['#1a73e8','#34a853','#fa7b17','#ea4335','#9334e6','#007b5e'],
    corporate: ['#2c3e50','#3498db','#2ecc71','#e74c3c','#f39c12','#9b59b6'],
};

/* ============================================================
   GENERADORES DE ETIQUETAS POR PERIODO
============================================================ */
const PERIODS = {
    daily() {
        const out = [], now = new Date();
        for (let i = 6; i >= 0; i--) {
            const d = new Date(now); d.setDate(d.getDate() - i);
            out.push(d.toLocaleDateString('es-MX', { weekday: 'short', day: 'numeric' }));
        }
        return out;
    },
    weekly() {
        const out = [], now = new Date();
        for (let i = 7; i >= 0; i--) {
            const d = new Date(now); d.setDate(d.getDate() - i * 7);
            out.push('S ' + d.toLocaleDateString('es-MX', { day: 'numeric', month: 'short' }));
        }
        return out;
    },
    monthly() {
        const names = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
        const m = new Date().getMonth();
        const arr = [];
        for (let i = 11; i >= 0; i--) arr.push(names[(m - i + 12) % 12]);
        return arr;
    },
    quarterly() { return ['Q1','Q2','Q3','Q4']; },
    yearly() {
        const y = new Date().getFullYear();
        return [y-4, y-3, y-2, y-1, y].map(String);
    },
};

/* Generador pseudo-aleatorio con semilla (LCG) — reproduce los mismos
   valores para la misma combinación de filtros activos */
function seededRng(seed) {
    let s = 0;
    for (let i = 0; i < seed.length; i++) s = (s * 31 + seed.charCodeAt(i)) >>> 0;
    return function() {
        s = (s * 1664525 + 1013904223) >>> 0;
        return s / 0xFFFFFFFF;
    };
}

function randArr(n, min = 10, max = 100, seed = '') {
    if (!seed) return Array.from({ length: n }, () => Math.floor(Math.random() * (max - min) + min));
    const rng = seededRng(seed);
    return Array.from({ length: n }, () => Math.floor(rng() * (max - min) + min));
}

/* ============================================================
   MAPA COLUMNAS POR TAMAÑO
============================================================ */
const SIZE_COL = {
    small:  'col-12 col-sm-6 col-md-4 col-lg-3',
    medium: 'col-12 col-sm-6 col-md-6 col-lg-4',
    large:  'col-12 col-md-8 col-lg-6',
    full:   'col-12',
};

/* ============================================================
   CONFIGURACIONES INICIALES DE WIDGETS
   (aquí puedes parametrizar tus propios widgets)
============================================================ */
const INITIAL_WIDGETS = [
    {
        id: 'w1', title: 'Ventas Mensuales',
        type: 'bar', period: 'monthly', colorScheme: 'blue', size: 'medium',
        opts: { legend: true, grid: true, anim: true, fill: false },
        datasetLabel: 'Ventas ($)',
    },
    {
        id: 'w2', title: 'Producción Semanal',
        type: 'line', period: 'weekly', colorScheme: 'green', size: 'medium',
        opts: { legend: true, grid: true, anim: true, fill: true },
        datasetLabel: 'Unidades',
    },
    {
        id: 'w3', title: 'Distribución por Área',
        type: 'doughnut', period: 'monthly', colorScheme: 'multi', size: 'small',
        opts: { legend: true, grid: false, anim: true, fill: false },
        datasetLabel: '%',
        fixedLabels: ['Calidad','Producción','Logística','RRHH','TI'],
    },
    {
        id: 'w4', title: 'Indicadores de Calidad',
        type: 'radar', period: 'monthly', colorScheme: 'purple', size: 'medium',
        opts: { legend: true, grid: true, anim: true, fill: true },
        datasetLabel: 'Índice',
        fixedLabels: ['Entrega','Calidad','Costo','Tiempo','Satisfacción','Seguridad'],
    },
    {
        id: 'w5', title: 'Ingresos Anuales',
        type: 'bar', period: 'yearly', colorScheme: 'corporate', size: 'large',
        opts: { legend: false, grid: true, anim: true, fill: false },
        datasetLabel: 'Ingresos ($M)',
    },
    {
        id: 'w6', title: 'Tickets por Categoría',
        type: 'pie', period: 'monthly', colorScheme: 'orange', size: 'small',
