        datasetLabel: 'Tickets',
        fixedLabels: ['Urgente','Normal','Bajo','Cerrado'],
    },
];

/* ============================================================
   CLASE ChartWidget  — contenedor reutilizable y parametrizable
============================================================ */
class ChartWidget {
    constructor(cfg) {
        this.cfg = { ...cfg };
    }

    /* Genera data según periodo, paleta y filtros activos globales */
    buildData() {
        const { period, colorScheme, type, fixedLabels, datasetLabel } = this.cfg;
        const labels  = fixedLabels || PERIODS[period]?.() || PERIODS.monthly();
        const palette = PALETTES[colorScheme] || PALETTES.blue;

        // Construye la semilla combinando el id del widget + filtros activos
        const filterSeed = getFilterSeed();
        const seed = filterSeed ? (this.cfg.id + '|' + filterSeed) : '';

        // Si hay filtros activos los rangos se ajustan para simular el subconjunto
        const activeCount = getActiveFilterCount();
        const maxVal = activeCount > 0 ? Math.max(30, 98 - activeCount * 8) : 98;
        const data = randArr(labels.length, 8, maxVal, seed);

        const isCircular = ['pie','doughnut','polarArea'].includes(type);
        const isArea     = type === 'area';
        const isRadar    = type === 'radar';

        return {
            labels,
            datasets: [{
                label: datasetLabel || 'Datos',
                data,
                backgroundColor: (isCircular || isRadar)
                    ? palette.slice(0, labels.length).map(c => c + 'bb')
                    : isArea ? palette[0] + '33' : palette[0] + 'cc',
                borderColor: isCircular ? palette.slice(0, labels.length) : palette[0],
                borderWidth: 2,
                fill: isArea || this.cfg.opts.fill,
                tension: 0.4,
                pointRadius: (type === 'line' || isArea) ? 4 : 0,
            }],
        };
    }

    /* Ensambla la config de Chart.js */
    buildChartConfig() {
        const { type, opts } = this.cfg;
        const isHBar      = type === 'horizontalBar';
        const chartType   = isHBar ? 'bar' : (type === 'area' ? 'line' : type);
        const noScales    = ['pie','doughnut','polarArea','radar'].includes(type);

        return {
            type: chartType,
            data: this.buildData(),
            options: {
                indexAxis: isHBar ? 'y' : 'x',
                responsive: true,
                maintainAspectRatio: false,
                animation: opts.anim ? undefined : false,
                plugins: {
                    legend: { display: opts.legend },
                    tooltip: { mode: 'index', intersect: false },
                },
                scales: noScales ? {} : {
                    x: { grid: { display: opts.grid, color: '#ececec' } },
                    y: { grid: { display: opts.grid, color: '#ececec' }, beginAtZero: true },
                },
            },
        };
    }

    /* Crea el elemento DOM del widget */
    buildElement() {
        const { id, title, size } = this.cfg;
        const col = document.createElement('div');
        col.className = SIZE_COL[size] || SIZE_COL.medium;
        col.id = `col-${id}`;
        col.dataset.wid = id;

        const isCircular = ['pie','doughnut','polarArea'].includes(this.cfg.type);
        const h = isCircular ? 'h-sm' : (size === 'large' || size === 'full' ? 'h-lg' : 'h-md');

        col.innerHTML = `
            <div class="widget-card" id="card-${id}">
                <div class="widget-title">${title}</div>
                <div class="widget-actions">
                    <button class="wbtn" title="Editar" onclick="selectWidget('${id}')">
                        <i class="bi bi-pencil-fill" style="font-size:.65rem;"></i>
                    </button>
                    <button class="wbtn" title="Actualizar datos" onclick="refreshWidget('${id}')">
                        <i class="bi bi-arrow-clockwise" style="font-size:.7rem;"></i>
                    </button>
                </div>
                <div class="chart-container ${h}">
                    <canvas id="cv-${id}"></canvas>
                </div>
            </div>`;

        col.querySelector(`#card-${id}`).addEventListener('click', e => {
            if (!e.target.closest('.wbtn')) selectWidget(id);
        });
        return col;
    }

    /* Monta el widget en un contenedor */
    mount(container, beforeEl = null) {
        const el = this.buildElement();
        if (beforeEl) container.insertBefore(el, beforeEl);
        else container.appendChild(el);
        this.initChart();
        return el;
    }

    /* (Re)inicia la instancia de Chart.js */
    initChart() {
        const { id } = this.cfg;
        if (chartInst[id]) { chartInst[id].destroy(); }
        const canvas = document.getElementById(`cv-${id}`);
        if (!canvas) return;
        chartInst[id] = new Chart(canvas.getContext('2d'), this.buildChartConfig());
    }

    /* Actualiza configuración y refresca */
    update(patch) {
        // Fusiona opts si vienen parcialmente
        if (patch.opts) patch.opts = { ...this.cfg.opts, ...patch.opts };
        Object.assign(this.cfg, patch);
        registry[this.cfg.id] = this.cfg;

        // Actualiza título visible
        const titleEl = document.querySelector(`#card-${this.cfg.id} .widget-title`);
        if (titleEl) titleEl.textContent = this.cfg.title;

        // Actualiza clase de columna (tamaño)
        const colEl = document.getElementById(`col-${this.cfg.id}`);
        if (colEl) colEl.className = SIZE_COL[this.cfg.size] || SIZE_COL.medium;

        this.initChart();
    }
}

/* ============================================================
   SISTEMA DE FILTROS BI
   activeFilters = { group: Set<val>, ... }
   Dentro de un grupo → lógica OR
   Entre grupos      → lógica AND
============================================================ */
const activeFilters = {};   // { 'area': Set{'Calidad','TI'}, 'turno': Set{'Turno A'} ... }

function getActiveFilterCount() {
    return Object.values(activeFilters).reduce((s, set) => s + set.size, 0);
}

/* Devuelve un string que identifica unívocamente la combinación de filtros */
function getFilterSeed() {
    const parts = Object.keys(activeFilters).sort().map(g => {
        const vals = [...activeFilters[g]].sort().join(',');
        return `${g}:${vals}`;
    }).filter(p => !p.endsWith(':'));
    return parts.join('|');
}

/* Alterna un chip y dispara la actualización de todos los widgets */
function toggleFilter(group, val, chipEl) {
    if (!activeFilters[group]) activeFilters[group] = new Set();
    const set = activeFilters[group];
    if (set.has(val)) {
        set.delete(val);
        chipEl.classList.remove('active');
    } else {
        set.add(val);
        chipEl.classList.add('active');
    }
    if (set.size === 0) delete activeFilters[group];
    renderFilterState();
    applyFiltersToAll();
}

/* Limpia todos los filtros activos */
function clearAllFilters() {
    Object.keys(activeFilters).forEach(k => delete activeFilters[k]);
    document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
    renderFilterState();
    applyFiltersToAll();
    toast('Filtros eliminados — mostrando todos los datos');
}

/* Elimina un filtro individual desde el tag de la cabecera */
function removeFilterTag(group, val) {
    if (activeFilters[group]) {
        activeFilters[group].delete(val);
        if (activeFilters[group].size === 0) delete activeFilters[group];
    }
    const chip = document.querySelector(`.filter-chip[data-group="${group}"][data-val="${val}"]`);
    if (chip) chip.classList.remove('active');
    renderFilterState();
    applyFiltersToAll();
}

/* Actualiza el badge de conteo, los tags inline y el botón "Limpiar todo" */
function renderFilterState() {
    const total = getActiveFilterCount();
    const badge = document.getElementById('filterCountBadge');
    const btnClear = document.getElementById('btnClearFilters');
    const tagsEl = document.getElementById('filterTagsInline');

    badge.textContent = total;
    badge.classList.toggle('visible', total > 0);
    btnClear.style.display = total > 0 ? '' : 'none';

    // Reconstruye tags inline
    tagsEl.innerHTML = '';
    Object.entries(activeFilters).forEach(([group, set]) => {
        set.forEach(val => {
            const tag = document.createElement('span');
            tag.className = 'filter-tag';
            tag.innerHTML = `${val} <span class="tag-x">×</span>`;
            tag.addEventListener('click', e => { e.stopPropagation(); removeFilterTag(group, val); });
            tagsEl.appendChild(tag);
        });
    });

    // Marca los widgets con el indicador "filtrado"
    document.querySelectorAll('.widget-card').forEach(c => c.classList.toggle('filtered', total > 0));
}

/* Re-renderiza todos los widgets con los filtros activos */
function applyFiltersToAll() {
    Object.values(instances).forEach(w => w.initChart());
}

/* Inicializa el panel de filtros: eventos de chips, toggle y colapso */
function initFilters() {
    // Toggle expandir/colapsar
    document.getElementById('filterBarHeader').addEventListener('click', () => {
        const body    = document.getElementById('filterBody');
        const chevron = document.getElementById('filterChevron');
        const open    = body.classList.toggle('open');
        chevron.style.transform = open ? 'rotate(180deg)' : '';
    });

    // Chips de filtros
    document.getElementById('filterBody').addEventListener('click', e => {
        const chip = e.target.closest('.filter-chip');
        if (!chip) return;
        toggleFilter(chip.dataset.group, chip.dataset.val, chip);
    });

    // Botón limpiar
    document.getElementById('btnClearFilters').addEventListener('click', e => {
        e.stopPropagation();
        clearAllFilters();
    });
}

/* ============================================================
   ESTADO GLOBAL
============================================================ */
const registry   = {};   // id → cfg
const instances  = {};   // id → ChartWidget
const chartInst  = {};   // id → Chart.js instance
let   activeId   = null; // widget seleccionado

/* ============================================================
   INICIALIZACIÓN DEL DASHBOARD
============================================================ */
function initDashboard() {
    initFilters();

    const grid   = document.getElementById('widgetGrid');
    const addBtn = buildAddBtn();
    grid.appendChild(addBtn);

    INITIAL_WIDGETS.forEach(cfg => {
        registry[cfg.id]  = { ...cfg };
        const w = new ChartWidget(cfg);
        instances[cfg.id] = w;
        w.mount(grid, addBtn);
    });
}

function buildAddBtn() {
    const col = document.createElement('div');
    col.className = 'col-12 col-sm-6 col-md-4 col-lg-3';
    col.id = 'addWidgetCol';
    col.innerHTML = `
        <div class="add-widget-placeholder" onclick="addWidget()">
            <i class="bi bi-plus-circle" style="font-size:2rem;"></i>
            <div style="margin-top:8px; font-size:.82rem;">Agregar widget</div>
        </div>`;
    return col;
}

/* ============================================================
   AGREGAR NUEVO WIDGET
============================================================ */
let wCounter = 20;
function addWidget(baseConfig = {}) {
    const id  = `w${++wCounter}`;
    const types   = ['bar','line','area','doughnut','pie','radar'];
    const schemes = Object.keys(PALETTES);
    const periods = Object.keys(PERIODS);

    const cfg = {
        id,
        title: `Widget ${wCounter}`,
        type:        types[Math.floor(Math.random() * types.length)],
        period:      periods[Math.floor(Math.random() * periods.length)],
        colorScheme: schemes[Math.floor(Math.random() * schemes.length)],
        size:        'medium',
        opts: { legend: true, grid: true, anim: true, fill: false },
        datasetLabel: 'Datos',
        ...baseConfig,
    };

    registry[id]  = cfg;
    const w = new ChartWidget(cfg);
    instances[id] = w;

    const addBtn = document.getElementById('addWidgetCol');
    w.mount(document.getElementById('widgetGrid'), addBtn);

    selectWidget(id);
    toast(`Widget "${cfg.title}" creado — personalízalo en el panel`);
}

/* ============================================================
   SELECCIONAR WIDGET → ABRIR PANEL
============================================================ */
function selectWidget(id) {
    activeId = id;
    const cfg = registry[id];
    if (!cfg) return;

    // Resaltar
    document.querySelectorAll('.widget-card').forEach(c => c.classList.remove('selected'));
    document.getElementById(`card-${id}`)?.classList.add('selected');

    // Llenar formulario
    document.getElementById('cfgTitle').value  = cfg.title;
    document.getElementById('cfgPeriod').value = cfg.period;

    document.querySelectorAll('.ct-btn').forEach(b =>
        b.classList.toggle('active', b.dataset.type === cfg.type));

    document.querySelectorAll('.swatch').forEach(s =>
        s.classList.toggle('active', s.dataset.scheme === cfg.colorScheme));

    const sizeEl = document.querySelector(`input[name="cfgSize"][value="${cfg.size}"]`);
    if (sizeEl) sizeEl.checked = true;

    document.getElementById('cfgLegend').checked = cfg.opts.legend;
    document.getElementById('cfgGrid').checked   = cfg.opts.grid;
    document.getElementById('cfgAnim').checked   = cfg.opts.anim;
    document.getElementById('cfgFill').checked   = cfg.opts.fill;

    // Actualizar cabecera del panel
    document.getElementById('panelSubtitle').textContent = cfg.title;
    document.getElementById('emptyMsg').style.display    = 'none';
    document.getElementById('cfgForm').style.display     = 'block';

    // Abrir panel
    openPanel();
}

function openPanel() {
    document.getElementById('configPanel').classList.add('open');
    document.getElementById('dbContent').classList.add('panel-open');
}

function closePanel() {
    document.getElementById('configPanel').classList.remove('open');
    document.getElementById('dbContent').classList.remove('panel-open');
    document.querySelectorAll('.widget-card').forEach(c => c.classList.remove('selected'));
    activeId = null;
}

/* ============================================================
   APLICAR CONFIGURACIÓN DESDE EL FORMULARIO
============================================================ */
function applyFormConfig() {
    if (!activeId) return;

    const type   = document.querySelector('.ct-btn.active')?.dataset.type   || 'bar';
    const scheme = document.querySelector('.swatch.active')?.dataset.scheme || 'blue';
    const size   = document.querySelector('input[name="cfgSize"]:checked')?.value || 'medium';

    instances[activeId].update({
        title:       document.getElementById('cfgTitle').value  || 'Widget',
        period:      document.getElementById('cfgPeriod').value,
        type, colorScheme: scheme, size,
        opts: {
            legend: document.getElementById('cfgLegend').checked,
            grid:   document.getElementById('cfgGrid').checked,
            anim:   document.getElementById('cfgAnim').checked,
            fill:   document.getElementById('cfgFill').checked,
        },
    });

    document.getElementById('panelSubtitle').textContent = registry[activeId].title;
    toast('Cambios aplicados');
}

/* ============================================================
   ELIMINAR WIDGET
============================================================ */
function deleteWidget() {
    if (!activeId) return;
    if (!confirm(`¿Eliminar "${registry[activeId]?.title}"?`)) return;

    const id = activeId;
    if (chartInst[id]) chartInst[id].destroy();
    document.getElementById(`col-${id}`)?.remove();
    delete registry[id]; delete instances[id]; delete chartInst[id];
    closePanel();
    toast('Widget eliminado');
}

/* ============================================================
   REFRESCAR DATOS DE UN WIDGET
============================================================ */
function refreshWidget(id) {
    instances[id]?.initChart();
    toast('Datos actualizados');
}

/* ============================================================
   CAMBIO DE PERIODO GLOBAL
============================================================ */
document.getElementById('globalPeriod').addEventListener('change', function () {
    const p = this.value;
    Object.values(instances).forEach(w => {
        if (!w.cfg.fixedLabels) w.update({ period: p });
    });
    toast(`Periodo global: ${this.options[this.selectedIndex].text}`);
});

/* ============================================================
   PARSEADOR DE COMANDOS EN TEXTO
   Formato: "tipo línea, color verde, periodo mensual, título Ventas, tamaño grande"
============================================================ */
const CMD = {
    tipo: {
        barra:'bar', barras:'bar', bar:'bar',
        'línea':'line', linea:'line', 'líneas':'line', lineas:'line', line:'line',
        'área':'area', area:'area',
        pastel:'pie', pie:'pie', circular:'pie',
        dona:'doughnut', doughnut:'doughnut', anillo:'doughnut',
        radar:'radar',
        polar:'polarArea', polararea:'polarArea',
        horizontal:'horizontalBar', 'h.bar':'horizontalBar',
    },
    color: {
        azul:'blue', blue:'blue',
        verde:'green', green:'green',
        rojo:'red', red:'red',
        morado:'purple', purple:'purple', violeta:'purple',
        naranja:'orange', orange:'orange',
        teal:'teal', turquesa:'teal', agua:'teal',
        multi:'multi', multicolor:'multi', colores:'multi',
        corporativo:'corporate', corporate:'corporate',
    },
    periodo: {
        diario:'daily', daily:'daily', 'día':'daily', dia:'daily',
        semanal:'weekly', weekly:'weekly', semana:'weekly',
        mensual:'monthly', monthly:'monthly', mes:'monthly',
        trimestral:'quarterly', quarterly:'quarterly', trimestre:'quarterly',
        anual:'yearly', yearly:'yearly', 'año':'yearly', ano:'yearly',
    },
    tamaño: {
        'pequeño':'small', pequeño:'small', small:'small', chico:'small',
        mediano:'medium', medium:'medium',
        grande:'large', large:'large',
        completo:'full', full:'full',
    },
};

function norm(str) {
    return str.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
}

function parseAndApplyCommand(raw) {
    if (!activeId) {
        toast('Selecciona primero un widget del dashboard', 'warn');
        return;
    }

    const txt     = norm(raw);
    const changes = {};
    let msg = [];

    // tipo: <val>
    const tm = txt.match(/tipo[:\s]+([a-z.]+)/);
    if (tm) { const v = CMD.tipo[tm[1]]; if (v) { changes.type = v; msg.push(`tipo → ${v}`); } }

    // color: <val>  o  color: #hex
    const cm = raw.match(/color[:\s]+([#a-zA-ZÁÉÍÓÚáéíóú]+)/i);
    if (cm) {
        const key = norm(cm[1]);
        if (CMD.color[key]) {
            changes.colorScheme = CMD.color[key];
            msg.push(`color → ${changes.colorScheme}`);
        } else if (/^#[0-9a-f]{3,6}$/i.test(cm[1])) {
            PALETTES['_hex'] = [cm[1], cm[1]+'cc', cm[1]+'99', cm[1]+'66', cm[1]+'44', cm[1]+'22'];
            changes.colorScheme = '_hex';
            msg.push(`color → ${cm[1]}`);
        }
    }

    // periodo: <val>
    const pm = txt.match(/periodo[:\s]+([a-z]+)/);
    if (pm) { const v = CMD.periodo[pm[1]]; if (v) { changes.period = v; msg.push(`periodo → ${v}`); } }

    // título: <texto>
    const titleM = raw.match(/t[íi]tulo[:\s]+(.+?)(?:,|$)/i);
    if (titleM) { changes.title = titleM[1].trim(); msg.push(`título → "${changes.title}"`); }

    // tamaño: <val>
    const sm = txt.match(/tama[nñ]o[:\s]+([a-z]+)/);
    if (sm) { const v = CMD.tamaño[sm[1]]; if (v) { changes.size = v; msg.push(`tamaño → ${v}`); } }

    if (!msg.length) {
        toast('Comando no reconocido. Prueba: tipo barra, color azul, periodo mensual', 'warn');
        return;
    }

    instances[activeId].update(changes);
    syncFormToActive();
    toast('Aplicado: ' + msg.join('  |  '));
}

function syncFormToActive() {
    if (!activeId) return;
    const cfg = registry[activeId];
    document.getElementById('cfgTitle').value  = cfg.title;
    document.getElementById('cfgPeriod').value = cfg.period;
    document.querySelectorAll('.ct-btn').forEach(b => b.classList.toggle('active', b.dataset.type === cfg.type));
    document.querySelectorAll('.swatch').forEach(s => s.classList.toggle('active', s.dataset.scheme === cfg.colorScheme));
    const sr = document.querySelector(`input[name="cfgSize"][value="${cfg.size}"]`);
    if (sr) sr.checked = true;
    document.getElementById('panelSubtitle').textContent = cfg.title;
}

/* ============================================================
   TOAST
============================================================ */
let toastTmr;
function toast(msg, type = '') {
    const el = document.getElementById('toastBar');
    el.textContent = msg;
    el.className   = 'toast-bar show' + (type === 'warn' ? ' warn' : '');
    clearTimeout(toastTmr);
    toastTmr = setTimeout(() => el.classList.remove('show'), 3000);
}

/* ============================================================
   EVENT LISTENERS
============================================================ */
// Panel
document.getElementById('btnTogglePanel').addEventListener('click', () => {
    document.getElementById('configPanel').classList.contains('open') ? closePanel() : openPanel();
});
document.getElementById('btnClosePanel').addEventListener('click', closePanel);
document.getElementById('btnApplyCfg').addEventListener('click', applyFormConfig);
document.getElementById('btnDeleteWidget').addEventListener('click', deleteWidget);
document.getElementById('btnAddWidget').addEventListener('click', () => addWidget());

// Chart type buttons (selección única)
document.getElementById('chartTypeGrid').addEventListener('click', e => {
    const b = e.target.closest('.ct-btn');
    if (!b) return;
    document.querySelectorAll('.ct-btn').forEach(x => x.classList.remove('active'));
    b.classList.add('active');
});

// Swatches de color (selección única)
document.getElementById('swatchRow').addEventListener('click', e => {
    const s = e.target.closest('.swatch');
    if (!s) return;
    document.querySelectorAll('.swatch').forEach(x => x.classList.remove('active'));
    s.classList.add('active');
});

// Color personalizado (hex picker)
document.getElementById('btnApplyHex').addEventListener('click', () => {
    if (!activeId) { toast('Selecciona un widget primero', 'warn'); return; }
    const hex = document.getElementById('cfgHex').value;
    PALETTES['_hex'] = [hex, hex+'cc', hex+'99', hex+'66', hex+'44', hex+'22'];
    document.querySelectorAll('.swatch').forEach(s => s.classList.remove('active'));
    instances[activeId].update({ colorScheme: '_hex' });
    toast(`Color hex ${hex} aplicado`);
});

// Comando de texto
function runCommand() {
    const inp = document.getElementById('cmdInput');
    parseAndApplyCommand(inp.value);
    inp.value = '';
}
document.getElementById('btnRunCmd').addEventListener('click', runCommand);
document.getElementById('cmdInput').addEventListener('keydown', e => {
    if (e.key === 'Enter') runCommand();
});

/* ============================================================
   ARRANQUE
============================================================ */
document.addEventListener('DOMContentLoaded', initDashboard);
</script>
</body>
</html>
