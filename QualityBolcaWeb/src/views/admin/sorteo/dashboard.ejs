<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard – Quality Bolca</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        /* ============================================================
           VARIABLES Y BASE
        ============================================================ */
        :root {
            --primary:      #1a73e8;
            --primary-dark: #1557b0;
            --bg-page:      #f0f2f5;
            --card-bg:      #ffffff;
            --panel-w:      380px;
            --topbar-h:     58px;
            --border:       #e0e0e0;
            --text-muted:   #888;
        }

        *, *::before, *::after { box-sizing: border-box; }
        body { background: var(--bg-page); font-family: 'Segoe UI', system-ui, sans-serif; margin: 0; }

        /* ============================================================
           TOPBAR
        ============================================================ */
        .db-topbar {
            height: var(--topbar-h);
            background: var(--card-bg);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 24px;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .db-topbar-brand { font-weight: 700; font-size: 1.05rem; color: #111; }
        .db-topbar-brand span { font-weight: 400; color: var(--text-muted); font-size: .85rem; }

        /* ============================================================
           DASHBOARD CONTENT
        ============================================================ */
        .db-content {
            padding: 24px;
            min-height: calc(100vh - var(--topbar-h));
            transition: margin-right .3s ease;
        }
        .db-content.panel-open { margin-right: var(--panel-w); }

        /* ============================================================
           WIDGET CARD  (el contenedor reutilizable)
        ============================================================ */
        .widget-card {
            background: var(--card-bg);
            border-radius: 14px;
            box-shadow: 0 1px 4px rgba(0,0,0,.07);
            padding: 18px 18px 14px;
            height: 100%;
            position: relative;
            cursor: pointer;
            transition: box-shadow .2s, outline .15s;
            outline: 2px solid transparent;
        }
        .widget-card:hover   { box-shadow: 0 4px 18px rgba(0,0,0,.11); }
        .widget-card.selected{ outline-color: var(--primary); box-shadow: 0 4px 20px rgba(26,115,232,.18); }

        .widget-title {
            font-size: .78rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .6px;
            color: #555;
            margin-bottom: 10px;
            padding-right: 56px; /* space for action buttons */
        }

        /* Botones flotantes sobre el widget */
        .widget-actions {
            position: absolute;
            top: 10px; right: 10px;
            display: none;
            gap: 5px;
        }
        .widget-card:hover .widget-actions,
        .widget-card.selected .widget-actions { display: flex; }

        .wbtn {
            background: #f5f5f5;
            border: none;
            border-radius: 7px;
            width: 26px; height: 26px;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer;
            font-size: .7rem;
            color: #555;
            transition: background .15s;
        }
        .wbtn:hover { background: #ddd; }

        /* Contenedor del canvas */
        .chart-container { position: relative; width: 100%; }
        .chart-container.h-sm  { height: 160px; }
        .chart-container.h-md  { height: 220px; }
        .chart-container.h-lg  { height: 300px; }

        /* ============================================================
           ADD WIDGET PLACEHOLDER
        ============================================================ */
        .add-widget-placeholder {
            border: 2px dashed #ccc;
            border-radius: 14px;
            min-height: 220px;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            cursor: pointer; color: #bbb;
            transition: all .2s; background: transparent;
        }
        .add-widget-placeholder:hover {
            border-color: var(--primary); color: var(--primary); background: #f0f4ff;
        }

        /* ============================================================
           CONFIG PANEL (panel lateral deslizable)
        ============================================================ */
        .config-panel {
            position: fixed;
            top: 0; right: -420px;
            width: var(--panel-w);
            height: 100vh;
            background: var(--card-bg);
            box-shadow: -4px 0 24px rgba(0,0,0,.1);
            z-index: 300;
            display: flex; flex-direction: column;
            transition: right .3s ease;
        }
        .config-panel.open { right: 0; }

        .panel-header {
            padding: 14px 18px;
            border-bottom: 1px solid var(--border);
            background: var(--card-bg);
            position: sticky; top: 0; z-index: 1;
            display: flex; align-items: center; justify-content: space-between;
        }
        .panel-header-info { font-size: .8rem; color: var(--text-muted); margin-top: 2px; }

        .panel-body {
            padding: 18px;
            flex: 1;
            overflow-y: auto;
        }

        /* Secciones del panel */
        .cfg-section { margin-bottom: 18px; }
        .cfg-label {
            font-size: .7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .7px;
            color: var(--text-muted);
            margin-bottom: 8px;
        }

        /* Selector de tipo de gráfico */
        .chart-type-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 6px;
        }
        .ct-btn {
            background: #f5f5f5;
            border: 2px solid transparent;
            border-radius: 8px;
            padding: 7px 3px 5px;
            text-align: center;
            cursor: pointer;
            font-size: .65rem;
            line-height: 1.3;
            color: #444;
            transition: all .15s;
        }
        .ct-btn i { display: block; font-size: 1.2rem; margin-bottom: 2px; }
        .ct-btn:hover  { background: #e8eaf6; }
        .ct-btn.active { background: #e8f0fe; border-color: var(--primary); color: var(--primary); }

        /* Paletas de color */
        .swatch-row { display: flex; flex-wrap: wrap; gap: 7px; }
        .swatch {
            width: 30px; height: 30px;
            border-radius: 7px;
            border: 2.5px solid transparent;
            cursor: pointer;
            transition: transform .15s, border-color .15s;
        }
        .swatch:hover  { transform: scale(1.12); }
        .swatch.active { border-color: #222; }

        /* ============================================================
           BARRA DE COMANDOS
        ============================================================ */
        .command-bar {
            padding: 14px 16px;
            border-top: 1px solid var(--border);
            background: #fafafa;
            flex-shrink: 0;
        }
        .cmd-label { font-size: .68rem; font-weight: 700; text-transform: uppercase; letter-spacing: .7px; color: var(--text-muted); margin-bottom: 6px; }
        .cmd-wrapper {
            display: flex; align-items: center; gap: 7px;
            background: #fff; border: 1.5px solid #ddd; border-radius: 10px; padding: 7px 10px;
            transition: border-color .2s;
        }
        .cmd-wrapper:focus-within { border-color: var(--primary); }
        .cmd-input { border: none; outline: none; flex: 1; font-size: .85rem; background: transparent; min-width: 0; }
        .cmd-btn {
            background: var(--primary); color: #fff; border: none;
            border-radius: 7px; padding: 4px 13px; font-size: .8rem; cursor: pointer;
            flex-shrink: 0;
        }
        .cmd-btn:hover { background: var(--primary-dark); }
        .cmd-hint { font-size: .67rem; color: #aaa; margin-top: 5px; line-height: 1.5; }

        /* ============================================================
           TOAST
        ============================================================ */
        .toast-bar {
            position: fixed; bottom: 22px; left: 50%;
            transform: translateX(-50%) translateY(70px);
            background: #323232; color: #fff;
            padding: 9px 20px; border-radius: 9px;
            font-size: .82rem; z-index: 9999;
            transition: transform .28s ease;
            pointer-events: none; white-space: nowrap;
        }
        .toast-bar.show { transform: translateX(-50%) translateY(0); }
        .toast-bar.warn  { background: #bf360c; }

        /* ============================================================
           BARRA DE FILTROS BI
        ============================================================ */
        .filter-bar {
            background: #fff;
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: var(--topbar-h);
            z-index: 90;
        }
        .filter-bar-header {
            display: flex; align-items: center; justify-content: space-between;
            padding: 9px 24px; cursor: pointer; user-select: none;
        }
        .filter-bar-title {
            font-size: .78rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: .6px;
            color: #555; display: flex; align-items: center; gap: 8px;
        }
        .filter-count-badge {
            background: var(--primary); color: #fff;
            font-size: .65rem; padding: 1px 7px;
            border-radius: 12px; font-weight: 700; display: none;
        }
        .filter-count-badge.visible { display: inline-block; }

        /* Tags de filtros activos en la cabecera (cuando está colapsado) */
        .filter-tag {
            background: #e8f0fe; color: var(--primary);
            border: 1px solid #c5d9fb; border-radius: 20px;
            font-size: .72rem; font-weight: 600;
            padding: 2px 9px 2px 8px;
            display: inline-flex; align-items: center; gap: 4px;
            cursor: pointer; transition: background .15s;
        }
        .filter-tag:hover { background: #d2e3fc; }
        .filter-tag .tag-x { font-size: .8rem; line-height: 1; }

        /* Cuerpo expandible */
        .filter-body {
            padding: 8px 24px 14px;
            border-top: 1px solid #f0f0f0;
            display: none;
        }
        .filter-body.open { display: block; }

        /* Fila de chips por categoría */
        .filter-row {
            display: flex; align-items: center;
            gap: 7px; margin-bottom: 8px; flex-wrap: wrap;
        }
        .filter-row:last-child { margin-bottom: 0; }
        .filter-row-label {
            font-size: .67rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: .5px;
            color: #aaa; min-width: 76px; flex-shrink: 0;
        }
        .filter-chip {
            background: #f5f5f5; border: 1.5px solid transparent;
            border-radius: 20px; font-size: .75rem;
            padding: 4px 13px; cursor: pointer;
            transition: all .15s; color: #444; user-select: none;
        }
        .filter-chip:hover { background: #eee; border-color: #ccc; }
        .filter-chip.active {
            background: #e8f0fe; border-color: var(--primary);
            color: var(--primary); font-weight: 600;
        }

        /* Indicador de datos filtrados sobre widget */
        .widget-card.filtered::after {
            content: '● filtrado';
            position: absolute; bottom: 8px; right: 10px;
            font-size: .62rem; color: var(--primary); font-weight: 600;
            letter-spacing: .3px; opacity: .7;
        }
    </style>
</head>
<body>

<!-- ============================================================
     TOPBAR
============================================================ -->
<header class="db-topbar">
    <div class="d-flex align-items-center gap-2">
        <span class="db-topbar-brand">Quality Bolca <span>/ Dashboard</span></span>
    </div>
    <div class="d-flex align-items-center gap-2">
        <select class="form-select form-select-sm" id="globalPeriod" style="width:auto; font-size:.82rem;">
            <option value="daily">Diario (7 días)</option>
            <option value="weekly">Semanal (8 semanas)</option>
            <option value="monthly" selected>Mensual (12 meses)</option>
            <option value="quarterly">Trimestral (4 trimestres)</option>
            <option value="yearly">Anual (5 años)</option>
        </select>
        <button class="btn btn-sm btn-outline-secondary" id="btnTogglePanel" style="font-size:.82rem;">
            <i class="bi bi-sliders"></i> Personalizar
        </button>
        <button class="btn btn-sm btn-primary" id="btnAddWidget" style="font-size:.82rem;">
            <i class="bi bi-plus-lg"></i> Widget
        </button>
    </div>
</header>

<!-- ============================================================
     BARRA DE FILTROS BI
============================================================ -->
<div class="filter-bar" id="filterBar">

    <!-- Cabecera (siempre visible) — clic para expandir/colapsar -->
    <div class="filter-bar-header" id="filterBarHeader">
        <div class="filter-bar-title">
            <i class="bi bi-funnel-fill" style="color:var(--primary); font-size:.85rem;"></i>
            Filtros
            <span class="filter-count-badge" id="filterCountBadge">0</span>
        </div>
        <div class="d-flex align-items-center gap-2" style="flex-wrap:wrap;">
            <!-- Tags de filtros activos (se muestran cuando el panel está colapsado) -->
            <div id="filterTagsInline" class="d-flex flex-wrap gap-1 align-items-center"></div>
            <button class="btn btn-sm btn-link text-danger p-0" id="btnClearFilters"
                style="font-size:.74rem; text-decoration:none; display:none;">
                <i class="bi bi-x-circle"></i> Limpiar todo
            </button>
            <i class="bi bi-chevron-down" id="filterChevron"
                style="font-size:.72rem; color:#bbb; transition:transform .2s; margin-left:4px;"></i>
        </div>
    </div>

    <!-- Cuerpo con chips de filtros (expandible) -->
    <div class="filter-body" id="filterBody">

        <div class="filter-row">
            <span class="filter-row-label">Área</span>
            <div class="filter-chip" data-group="area" data-val="Producción">Producción</div>
            <div class="filter-chip" data-group="area" data-val="Calidad">Calidad</div>
            <div class="filter-chip" data-group="area" data-val="Logística">Logística</div>
            <div class="filter-chip" data-group="area" data-val="RRHH">RRHH</div>
            <div class="filter-chip" data-group="area" data-val="TI">TI</div>
            <div class="filter-chip" data-group="area" data-val="Mantenimiento">Mantenimiento</div>
        </div>

        <div class="filter-row">
            <span class="filter-row-label">Turno</span>
            <div class="filter-chip" data-group="turno" data-val="Turno A">Turno A</div>
            <div class="filter-chip" data-group="turno" data-val="Turno B">Turno B</div>
            <div class="filter-chip" data-group="turno" data-val="Turno C">Turno C</div>
        </div>

        <div class="filter-row">
            <span class="filter-row-label">Línea</span>
            <div class="filter-chip" data-group="linea" data-val="Línea 1">Línea 1</div>
            <div class="filter-chip" data-group="linea" data-val="Línea 2">Línea 2</div>
            <div class="filter-chip" data-group="linea" data-val="Línea 3">Línea 3</div>
            <div class="filter-chip" data-group="linea" data-val="Línea 4">Línea 4</div>
        </div>

        <div class="filter-row">
            <span class="filter-row-label">Estado</span>
            <div class="filter-chip" data-group="estado" data-val="Activo">Activo</div>
            <div class="filter-chip" data-group="estado" data-val="En proceso">En proceso</div>
            <div class="filter-chip" data-group="estado" data-val="Completado">Completado</div>
            <div class="filter-chip" data-group="estado" data-val="Cancelado">Cancelado</div>
        </div>

    </div>
</div>

<!-- ============================================================
     CONTENIDO DEL DASHBOARD
============================================================ -->
<main class="db-content" id="dbContent">
    <div class="row g-3" id="widgetGrid">
        <!-- Los widgets se inyectan aquí por JavaScript -->
    </div>
</main>

<!-- ============================================================
     PANEL DE CONFIGURACIÓN (lateral deslizable)
============================================================ -->
<aside class="config-panel" id="configPanel">

    <div class="panel-header">
        <div>
            <div style="font-weight:600; font-size:.93rem;">Configurar Widget</div>
            <div class="panel-header-info" id="panelSubtitle">Selecciona un widget del dashboard</div>
        </div>
        <button class="btn-close" id="btnClosePanel" aria-label="Cerrar"></button>
    </div>

    <div class="panel-body" id="panelBody">

        <!-- Mensaje vacío -->
        <div class="text-center text-muted py-5" id="emptyMsg">
            <i class="bi bi-cursor-fill" style="font-size:2.2rem; opacity:.35;"></i>
            <div style="margin-top:10px; font-size:.83rem;">Haz clic en cualquier gráfico del dashboard para editar sus propiedades aquí.</div>
        </div>

        <!-- Formulario de configuración (se muestra al seleccionar un widget) -->
        <div id="cfgForm" style="display:none;">

            <!-- Título -->
            <div class="cfg-section">
                <div class="cfg-label">Título</div>
                <input type="text" class="form-control form-control-sm" id="cfgTitle" placeholder="Ej: Ventas Mensuales">
            </div>

            <!-- Tipo de gráfico -->
            <div class="cfg-section">
                <div class="cfg-label">Tipo de Gráfico</div>
                <div class="chart-type-grid" id="chartTypeGrid">
                    <div class="ct-btn active" data-type="bar">       <i class="bi bi-bar-chart-fill"></i>Barras</div>
                    <div class="ct-btn" data-type="line">             <i class="bi bi-graph-up"></i>Líneas</div>
                    <div class="ct-btn" data-type="area">             <i class="bi bi-graph-up-arrow"></i>Área</div>
                    <div class="ct-btn" data-type="pie">              <i class="bi bi-pie-chart-fill"></i>Pastel</div>
                    <div class="ct-btn" data-type="doughnut">         <i class="bi bi-circle"></i>Dona</div>
                    <div class="ct-btn" data-type="radar">            <i class="bi bi-star-fill"></i>Radar</div>
                    <div class="ct-btn" data-type="polarArea">        <i class="bi bi-asterisk"></i>Polar</div>
                    <div class="ct-btn" data-type="horizontalBar">    <i class="bi bi-bar-chart-steps"></i>H.Bar</div>
                </div>
            </div>

            <!-- Periodo -->
            <div class="cfg-section">
                <div class="cfg-label">Periodo de Datos</div>
                <select class="form-select form-select-sm" id="cfgPeriod">
                    <option value="daily">Diario — últimos 7 días</option>
                    <option value="weekly">Semanal — últimas 8 semanas</option>
                    <option value="monthly">Mensual — últimos 12 meses</option>
                    <option value="quarterly">Trimestral — últimos 4 trimestres</option>
                    <option value="yearly">Anual — últimos 5 años</option>
                </select>
            </div>

            <!-- Esquema de color -->
            <div class="cfg-section">
                <div class="cfg-label">Esquema de Color</div>
                <div class="swatch-row" id="swatchRow">
                    <div class="swatch active" data-scheme="blue"      style="background:#1a73e8" title="Azul"></div>
                    <div class="swatch"        data-scheme="green"     style="background:#34a853" title="Verde"></div>
                    <div class="swatch"        data-scheme="red"       style="background:#ea4335" title="Rojo"></div>
                    <div class="swatch"        data-scheme="purple"    style="background:#9334e6" title="Morado"></div>
                    <div class="swatch"        data-scheme="orange"    style="background:#fa7b17" title="Naranja"></div>
                    <div class="swatch"        data-scheme="teal"      style="background:#007b5e" title="Teal"></div>
                    <div class="swatch"        data-scheme="multi"     style="background:linear-gradient(135deg,#1a73e8,#34a853,#fa7b17)" title="Multicolor"></div>
                    <div class="swatch"        data-scheme="corporate" style="background:linear-gradient(135deg,#2c3e50,#3498db)" title="Corporativo"></div>
                </div>
                <!-- Color exacto -->
                <div class="d-flex align-items-center gap-2 mt-2">
                    <input type="color" class="form-control form-control-color form-control-sm" id="cfgHex" value="#1a73e8" style="width:40px; height:30px; padding:2px;">
                    <button class="btn btn-sm btn-outline-secondary" id="btnApplyHex" style="font-size:.75rem;">Aplicar hex</button>
                </div>
            </div>

            <!-- Tamaño -->
            <div class="cfg-section">
                <div class="cfg-label">Tamaño del Widget</div>
                <div class="btn-group w-100" role="group">
                    <input type="radio" class="btn-check" name="cfgSize" id="szSm"   value="small"  autocomplete="off">
                    <label class="btn btn-sm btn-outline-secondary" for="szSm"  style="font-size:.75rem;">Pequeño</label>
                    <input type="radio" class="btn-check" name="cfgSize" id="szMd"   value="medium" autocomplete="off" checked>
                    <label class="btn btn-sm btn-outline-secondary" for="szMd"  style="font-size:.75rem;">Mediano</label>
                    <input type="radio" class="btn-check" name="cfgSize" id="szLg"   value="large"  autocomplete="off">
                    <label class="btn btn-sm btn-outline-secondary" for="szLg"  style="font-size:.75rem;">Grande</label>
                    <input type="radio" class="btn-check" name="cfgSize" id="szFull" value="full"   autocomplete="off">
                    <label class="btn btn-sm btn-outline-secondary" for="szFull" style="font-size:.75rem;">Completo</label>
                </div>
            </div>

            <!-- Opciones adicionales -->
            <div class="cfg-section">
                <div class="cfg-label">Opciones</div>
                <div class="d-flex flex-column gap-2">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="cfgLegend" checked>
                        <label class="form-check-label" for="cfgLegend" style="font-size:.83rem;">Mostrar leyenda</label>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="cfgGrid" checked>
                        <label class="form-check-label" for="cfgGrid" style="font-size:.83rem;">Cuadrícula</label>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="cfgAnim" checked>
                        <label class="form-check-label" for="cfgAnim" style="font-size:.83rem;">Animación</label>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="cfgFill">
                        <label class="form-check-label" for="cfgFill" style="font-size:.83rem;">Relleno bajo la línea</label>
                    </div>
                </div>
            </div>

            <button class="btn btn-primary w-100 mb-2" id="btnApplyCfg" style="font-size:.85rem;">
                <i class="bi bi-check-lg"></i> Aplicar Cambios
            </button>
            <button class="btn btn-outline-danger w-100" id="btnDeleteWidget" style="font-size:.78rem;">
                <i class="bi bi-trash3"></i> Eliminar Widget
            </button>

        </div><!-- /cfgForm -->
    </div><!-- /panelBody -->

    <!-- ---- BARRA DE COMANDOS EN TEXTO ---- -->
    <div class="command-bar">
        <div class="cmd-label">Comando rápido</div>
        <div class="cmd-wrapper">
            <i class="bi bi-terminal" style="color:#bbb; font-size:.9rem; flex-shrink:0;"></i>
            <input type="text" class="cmd-input" id="cmdInput"
                placeholder='ej: tipo línea, color verde, periodo mensual'>
            <button class="cmd-btn" id="btnRunCmd"><i class="bi bi-send-fill"></i></button>
        </div>
        <div class="cmd-hint">
            <strong>tipo</strong>: barra·línea·área·pastel·dona·radar·polar·horizontal &nbsp;|&nbsp;
            <strong>color</strong>: azul·verde·rojo·morado·naranja·teal·multi &nbsp;|&nbsp;
            <strong>periodo</strong>: diario·semanal·mensual·trimestral·anual &nbsp;|&nbsp;
            <strong>título</strong>: [texto] &nbsp;|&nbsp;
            <strong>tamaño</strong>: pequeño·mediano·grande·completo
        </div>
    </div>

</aside>

<!-- TOAST -->
<div class="toast-bar" id="toastBar"></div>

<!-- ============================================================
     SCRIPTS
============================================================ -->
