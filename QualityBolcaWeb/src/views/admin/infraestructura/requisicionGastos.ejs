<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= tok %>">
    <title>Requisiciones de gastos</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/styles/infraestructura/requisicionGastos.css">
</head>

<body>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>
    <aside class="sidebar" id="sidebar">

        <div class="logo-container">
            <div class="logo-icon"><i class="fa-solid fa-wallet"></i></div>
            <span>Requisiciones</span>
        </div>

        <div class="profile-section">
            <div class="avatar" id="avatarUsuario"></div>

            <div class="profile-name">
                <%= usuario.nombrelargo %>
            </div>

            <div class="profile-role">
                <%= usuario.puesto || '' %>
            </div>

            <div class="profile-dept">
                <%= usuario.departamento || '' %>
            </div>

            <div class="profile-email">
                <%= usuario.correoelectronico %>
            </div>
        </div>

        <ul class="nav-menu">
            <a href="requisicionGastos" class="nav-item active">
                <i class="fa-solid fa-border-all"></i> Panel Principal
            </a>

            <a href="misRequisiciones" class="nav-item">
                <i class="fa-solid fa-file-lines"></i> Mis Requisiciones
            </a>

            <% if (jerarquia <=4) { %>
                <a href="aprobaciones" class="nav-item">
                    <i class="fa-solid fa-check-double"></i> Aprobaciones
                </a>

                <a href="comprobar" class="nav-item">
                    <i class="fa-solid fa-file-invoice"></i> Comprobaciones
                </a>
                <% } %>
        </ul>

    </aside>

    <main class="main-content">
        <header class="top-bar">
            <button class="menu-toggle" id="menuToggle" onclick="toggleSidebar()">
                <i class="fa-solid fa-bars"></i>
            </button>
            <div class="search-bar">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" placeholder="Buscar requisiciones, folios o conceptos...">
            </div>
            <div class="top-actions">
                <button class="btn btn-primary" onclick="location.href='crearRequisicionGastos'"><i
                        class="fa-solid fa-plus"></i> Crear Requisición</button>
                <button class="btn btn-refresh" id="btnRefresh">
                    <i class="fa-solid fa-rotate"></i> Actualizar
                </button>
            </div>
        </header>

        <div class="dashboard-body">

            <section class="summary-cards">

                <div class="card summary-card">
                    <div class="card-icon warning-bg">
                        <i class="fa-solid fa-clipboard-list warning-text"></i>
                    </div>
                    <div class="card-info">
                        <span class="card-label">
                            <% if (esSuperAdmin) { %>
                                TOTAL PENDIENTES (SISTEMA)
                            <% } else if (esNivelAlto) { %>
                                PENDIENTES DE MI DEPARTAMENTO
                            <% } else { %>
                                PENDIENTES DE CONFIRMACIÓN
                            <% } %>
                        </span>
                        <h2 id="monto-pendientes"><%= pendientesConfirmacion %></h2>
                    </div>
                </div>

                <% if (jerarquia <= 4 || esNivelAlto || esSuperAdmin) { %>
                    <div class="card summary-card">
                        <div class="card-icon blue-bg">
                            <i class="fa-solid fa-file-signature blue-text"></i>
                        </div>
                        <div class="card-info">
                            <span class="card-label">POR COMPROBAR</span>
                            <h2>
                                <span id="solicitudes-comprobar"><%= porComprobar %></span>
                                <small>solicitudes</small>
                            </h2>
                        </div>
                    </div>

                    <div class="card summary-card">
                        <div class="card-icon purple-bg">
                            <i class="fa-solid fa-check-double purple-text"></i>
                        </div>
                        <div class="card-info">
                            <span class="card-label">
                                <% if (esSuperAdmin) { %>
                                    POR APROBAR (TOTAL)
                                <% } else { %>
                                    POR APROBAR (MI DEPTO.)
                                <% } %>
                            </span>
                            <h2>
                                <span id="solicitudes-aprobar"><%= stats.total_pendientes %></span>
                                <small>solicitudes</small>
                            </h2>
                        </div>
                    </div>
                <% } %>

                <div class="card summary-card">
                    <div class="card-icon success-bg">
                        <i class="fa-solid fa-circle-check success-text"></i>
                    </div>
                    <div class="card-info">
                        <span class="card-label">TOTAL MES</span>
                        <h2 id="monto-total">
                            <%= new Intl.NumberFormat('es-MX', { style: 'currency', currency: 'MXN' }).format(montoTotalMes) %>
                        </h2>
                    </div>
                </div>

            </section>

            <section class="table-section">
                <div class="section-header">
                    <h3><i class="fa-solid fa-arrow-up-from-bracket warning-text"></i> Requisiciones Enviadas
                        (Pendientes de Confirmación)</h3>
                    <a href="misRequisiciones" class="link">Ver todas</a>
                </div>
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>FECHA</th>
                                <th>CONCEPTO</th>
                                <th>MONTO</th>
                                <th>ESTATUS</th>
                                <th>ACCIÓN</th>
                            </tr>
                        </thead>
                        <tbody id="tabla-requisiciones">
                        </tbody>
                    </table>
                </div>
            </section>

            <!-- Pendiente seccion de comprobaciones -->
            <section class="cards-section">
                <div class="section-header">
                    <h3><i class="fa-solid fa-check-double blue-text"></i> Requisiciones Recibidas (Pendientes de
                        Comprobación)</h3>
                    <a href="comprobar" class="link">Ver todas</a>
                </div>
                <div class="action-cards-grid" id="tarjetas-comprobacion">
                </div>
            </section>

        </div>
    </main>

    <script>
        const esNivelAlto = <%- JSON.stringify(esNivelAlto) %>;
        const esSuperAdmin = <%- JSON.stringify(esSuperAdmin) %>;
    </script>
    <script>
        const nombreUsuario = "<%= usuario.nombrelargo %>"
    </script>

    <script src="/scripts/infraestructura/requisicionGastos.js"></script>
</body>

</html>