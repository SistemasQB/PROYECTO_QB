<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Órdenes de Compra - Quality Bolca</title>
    
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <%-include('partials/menu-hamburguesa.ejs')%>

    <!-- Main Content -->
    <main class="main-content">
        <div class="container">
            <div class="page-header">
                <h1>Órdenes de Compra</h1>
                <p>Gestiona y revisa todas las órdenes de compra realizadas</p>
            </div>

            <!-- ===== SECCIÓN BÚSQUEDA POR FECHA ===== -->
            <div class="date-filter-card">
                <div class="date-filter-header">
                    <div class="date-filter-title">
                        <i class="fas fa-calendar-alt"></i>
                        <h2>Consulta por Rango de Fechas</h2>
                    </div>
                </div>
                <div class="date-filter-body">
                    <div class="date-filter-inputs">
                        <div class="date-input-group">
                            <label for="fechaInicio"><i class="fas fa-calendar-day"></i> Fecha inicio</label>
                            <input type="date" id="fechaInicio">
                        </div>
                        <div class="date-filter-separator">—</div>
                        <div class="date-input-group">
                            <label for="fechaFin"><i class="fas fa-calendar-check"></i> Fecha fin</label>
                            <input type="date" id="fechaFin">
                        </div>
                        <button class="btn-primary btn-buscar" onclick="buscarPorFecha()">
                            <i class="fas fa-search"></i> Buscar
                        </button>
                        <button class="btn-secondary btn-limpiar" onclick="limpiarBusqueda()">
                            <i class="fas fa-times"></i> Limpiar
                        </button>
                    </div>
                </div>
            </div>

            <!-- ===== TABLA 1: TODAS LAS ÓRDENES ===== -->
            <div class="table-section">
                <div class="table-section-header" onclick="toggleSection('seccionTabla1', 'iconTabla1')">
                    <div class="table-section-title">
                        <i class="fas fa-list-alt"></i>
                        <h2>Todas las Órdenes de Compra</h2>
                    </div>
                    <i class="fas fa-chevron-up toggle-icon" id="iconTabla1"></i>
                </div>

                <div id="seccionTabla1">
                    <!-- Search Section -->
                    <div class="search-section">
                        <div class="search-container">
                            <i class="fas fa-search search-icon"></i>
                            <input type="text" id="searchInput" placeholder="Buscar por fecha, lugar, proveedor..." onkeyup="filterTable()">
                        </div>
                        <a class="btn-primary" id="btnNuevaOrden" href="ordenCompra">
                            Nueva Orden
                        </a>
                    </div>

                    <!-- Orders Table -->
                    <div class="table-container">
                        <table class="orders-table" id="ordersTable">
                            <thead>
                                <tr>
                                    <th>Número de Orden</th>
                                    <th>Fecha</th>
                                    <th>Lugar</th>
                                    <th>Proveedor</th>
                                    <th>Solicitudes</th>
                                    <th>Observaciones</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="tablaOrdenes"></tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- ===== TABLA 2: RESULTADOS POR FECHA ===== -->
            <div class="table-section" id="seccionResultadosFecha" style="display:none;">
                <div class="table-section-header" onclick="toggleSection('seccionTabla2', 'iconTabla2')">
                    <div class="table-section-title">
                        <i class="fas fa-filter"></i>
                        <h2>Resultados por Rango de Fechas</h2>
                        <span class="badge-resultados" id="badgeResultados">0 resultados</span>
                    </div>
                    <i class="fas fa-chevron-up toggle-icon" id="iconTabla2"></i>
                </div>

                <div id="seccionTabla2">
                    <div class="table-container">
                        <table class="orders-table" id="ordersTableFecha">
                            <thead>
                                <tr>
                                    <th>Número de Orden</th>
                                    <th>Fecha</th>
                                    <th>Lugar</th>
                                    <th>Proveedor</th>
                                    <th>Solicitudes</th>
                                    <th>Observaciones</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="tablaOrdenesFecha"></tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </main>

    <!-- Edit Modal -->
    <div class="modal" id="editModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Editar Orden de Compra</h3>
                <button class="close-btn" onclick="closeEditModal()">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <form class="modal-form" id="editForm">
                <div class="form-group">
                    <label for="editFecha">Fecha:</label>
                    <input type="date" id="editFecha" required>
                </div>
                <div class="form-group">
                    <label for="editLugar">Lugar:</label>
                    <input type="text" id="editLugar" required>
                </div>
                <div class="form-group">
                    <label for="editProveedor">Proveedor:</label>
                    <input type="text" id="editProveedor" required>
                </div>
                <div class="table-container">
                    <div class="section-header">
                        <h3>Productos/Servicios</h3>
                        <button type="button" id="addRowBtn" class="btn btn-secondary">+ Agregar Fila</button>
                    </div>
                    <table id="productsTable">
                        <thead>
                            <tr>
                                <th>No. Item</th>
                                <th>Servicio/Producto</th>
                                <th>Cantidad</th>
                                <th>Precio Unitario</th>
                                <th>Precio Total</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="productsTableBody"></tbody>
                    </table>
                </div>
                <div class="form-group-t">
                    <div class="totals-section">
                        <div class="totals-grid">
                            <div class="total-item">
                                <label>Subtotal:</label>
                                <span id="subtotal">$0.00</span>
                            </div>
                            <div class="total-item">
                                <label>IVA (16%):</label>
                                <span id="iva">$0.00</span>
                            </div>
                            <div class="total-item total-final">
                                <label>Total:</label>
                                <span id="total">$0.00</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label for="editObservaciones">Observaciones:</label>
                    <textarea id="editObservaciones" rows="3"></textarea>
                </div>
                <div class="modal-actions">
                    <button type="button" class="btn-secondary" onclick="closeEditModal()">Cancelar</button>
                    <button type="button" class="btn-primary" id="btnSaveChanges">Guardar Cambios</button>
                </div>
            </form>
        </div>
    </div>

    <!-- View Modal (visualizar orden) -->
    <div class="modal" id="viewModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-eye" style="margin-right:8px;color:#4a90e2;"></i>Visualizar Orden de Compra</h3>
                <button class="close-btn" onclick="closeViewModal()">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="modal-form" id="viewContent">
                <!-- Se rellena dinámicamente -->
            </div>
        </div>
    </div>

    <script src="/scripts/infraestructura/scripts_global.js"></script>
    <script src="/scripts/infraestructura/scripts_historico_ordenesordenes_compra.js"></script>
    <script src="/scripts/calidad/funcion_fetch_calidad.js"></script>
    <link rel="stylesheet" href="/styles/infraestructura/estilos_historico_ordenes_compra.css">
    <script>
        let ordenes = <%-JSON.stringify(ordenes);%>
        let tok = <%-JSON.stringify(tok);%>
    </script>
</body>
</html>
