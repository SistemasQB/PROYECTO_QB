<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aprobaciones de requisiciones</title>
    <meta name="csrf-token" content="<%= tok %>">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles/infraestructura/aprobacionesRequisicionGastos.css">
</head>

<body>

    <aside class="sidebar" id="sidebar">
        <div class="logo-container">
            <div class="logo-icon"><i class="fa-solid fa-wallet"></i></div>
            <span>Requisiciones</span>
        </div>

        <div class="profile-section">
            <div class="avatar" id="avatarUsuario"></div>
            <div class="profile-name">
                <%= usuario.nombrelargo %>
            </div>
            <div class="profile-role">
                <%= usuario.puesto || '' %>
            </div>
            <div class="profile-dept">
                <%= usuario.departamento || '' %>
            </div>
            <div class="profile-email">
                <%= usuario.correoelectronico %>
            </div>
        </div>

        <ul class="nav-menu">
            <a href="requisicionGastos" class="nav-item"><i class="fa-solid fa-border-all"></i> Panel Principal</a>
            <a href="requisiciones" class="nav-item"><i class="fa-solid fa-file-lines"></i> Mis Requisiciones</a>
            <a href="aprobaciones" class="nav-item active"><i class="fa-solid fa-check-double"></i> Aprobaciones</a>
            <a href="comprobaciones" class="nav-item"><i class="fa-solid fa-file-invoice"></i> Comprobaciones</a>
        </ul>
    </aside>

    <div class="main-wrapper">
        <header class="topbar">
            <button class="menu-toggle" onclick="toggleSidebar()"><i class="fa-solid fa-bars"></i></button>
            <div class="search-bar">
                <i class="fa-solid fa-magnifying-glass" style="color: #adb5bd;"></i>
                <input type="text" placeholder="Buscar requisiciones, folios o conceptos...">
            </div>
        </header>

        <main class="content">
            <h1 class="page-title">Aprobación de Requisiciones</h1>

            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-header">
                        <span>Requisiciones Pendientes</span>
                        <i class="fa-solid fa-clipboard-list" style="color: var(--primary-blue);"></i>
                    </div>
                    <div class="stat-value">
                        <%= stats.total_pendientes %>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-header">
                        <span>Monto Total Pendiente</span>
                        <i class="fa-solid fa-money-bill-wave" style="color: var(--primary-blue);"></i>
                    </div>
                    <div class="stat-value">
                        $<%= Number(stats.monto_total).toLocaleString('es-MX') %>
                            <span class="stat-sub text-muted">MXN</span>
                    </div>
                </div>
            </div>

            <div class="table-container">
                <div class="table-responsive">
                    <table>
                        <thead>
                            <tr>
                                <th>Folio</th>
                                <th>Asunto</th>
                                <th>Fecha de Solicitud</th>
                                <th>Solicitante</th>
                                <th>Departamento</th>
                                <th>Monto</th>
                                <th>Acción</th>
                            </tr>
                        </thead>
                        <tbody id="tabla-requisiciones">
                            <% if (requisiciones.length===0) { %>
                                <tr>
                                    <td colspan="6" style="text-align:center; padding:20px;">
                                        No hay requisiciones pendientes
                                    </td>
                                </tr>
                                <% } %>

                                    <% requisiciones.forEach(req=> { %>
                                        <tr>
                                            <td style="color: var(--primary-blue); font-weight: 600;">
                                                #REQ-<%= req.id %>
                                            </td>

                                            <td>
                                                <%= req.asunto %>
                                            </td>

                                            <td>
                                                <%= new Date(req.horaRegistro).toLocaleDateString('es-MX') %>
                                            </td>

                                            <td>
                                                <div class="solicitante">
                                                    <div class="solicitante-avatar"
                                                        data-nombre="<%= req.solicitante %>">
                                                        <%= req.solicitante?.charAt(0) || 'U' %>
                                                    </div>
                                                    <%= req.solicitante %>
                                                </div>
                                            </td>

                                            <td>
                                                <span class="tag">
                                                    <%= req.departamento %>
                                                </span>
                                            </td>

                                            <td style="font-weight: 600;">
                                                $<%= Number(req.total).toLocaleString('es-MX') %>
                                            </td>

                                            <td>
                                                <button class="btn-outline verRequisicion"
                                                    onclick="abrirModal(<%= req.id %>)">
                                                    Ver Detalle
                                                </button>
                                            </td>
                                        </tr>
                                        <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

        </main>
    </div>

    <div id="modal-root"></div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const nombreUsuario = "<%= usuario.nombrelargo %>"
    </script>
    <script>
        const esSuperAdmin = <% - JSON.stringify(esSuperAdmin) %>;
        const esNivelAlto = <% - JSON.stringify(esNivelAlto) %>;
    </script>
    <script src="/scripts/infraestructura/aprobacionesRequisicionGastos.js"></script>
</body>

</html>