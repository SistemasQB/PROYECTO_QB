<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Reporte Publicado | Quality Bolca</title>
  <link rel="stylesheet" href="/styles/supervisor/estilos_supervisor.css" />
  <meta name="csrf-token" content="<%= csrfToken %>">
</head>
<body>

  <!-- P-08: DETALLE DE REPORTE PUBLICADO (solo lectura) -->

  <!-- Header -->
  <header class="sv-header">
    <!-- Botón hamburguesa: visible solo en móvil/tablet (≤768px) -->
    <button
      class="sv-hamburger"
      id="sv-hamburger-btn"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="sv-sidebar-nav"
    >
      <svg class="sv-hamburger__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="6"  x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>

    <div class="sv-header__brand">
      <img
        class="sv-header__logo"
        src="https://qualitybolca.com/assets/images/logo.png"
        alt="Quality Bolca"
        onerror="this.style.display='none'"
      />
    </div>
    <div class="sv-header__actions">
      <span class="sv-header__username"><%= supervisor ? supervisor.nombre : 'N/A' %></span>
      <a
        href="/bots/supervisor/historial"
        class="sv-btn sv-btn--ghost"
        aria-label="Volver al historial"
      >
        &larr; Volver al historial
      </a>
    </div>
  </header>

  <!-- Overlay oscuro: cubre el contenido al abrir el drawer en móvil -->
  <div class="sv-sidebar-overlay" id="sv-sidebar-overlay" aria-hidden="true"></div>

  <div class="sv-layout">

    <!-- Sidebar -->
    <nav class="sv-sidebar" id="sv-sidebar-nav" aria-label="Navegación principal">
      <div class="sv-sidebar__brand">
        <img src="https://qualitybolca.com/assets/images/logo.png" alt="Quality Bolca" onerror="this.style.display='none'" />
      </div>
      <ul class="sv-sidebar__list">
        <li>
          <a
            href="/bots/supervisor/bandeja"
            class="sv-sidebar__item"
          >
            <svg class="sv-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
            Bandeja
          </a>
        </li>
        <li>
          <a
            href="/bots/supervisor/historial"
            class="sv-sidebar__item sv-sidebar__item--active"
            aria-current="page"
          >
            <svg class="sv-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
            Historial publicados
          </a>
        </li>
        <li>
          <button class="sv-sidebar__item">
            <svg class="sv-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
            Mi perfil
          </button>
        </li>
      </ul>
    </nav>

    <!-- Contenido principal -->
    <main class="sv-main">
      <div class="sv-page-header sv-page-header--row">
        <div>
          <h1 class="sv-page-title">Reporte de Inspección</h1>
          <p class="sv-page-subtitle">
            <%= reporte.nombre_inspector || 'N/A' %> &middot;
            <%= cotizacion.numero_parte || 'N/A' %> &middot;
            <%= new Date(reporte.created_at).toLocaleDateString('es-MX') %> <%= reporte.turno || '' %>
          </p>
        </div>
        <span class="sv-badge sv-badge--success sv-badge--lg">PUBLICADO</span>
      </div>

      <!-- Franja de auditoría -->
      <div class="sv-audit-strip" aria-label="Información de auditoría">
        <div class="sv-audit-strip__item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" aria-hidden="true">
            <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span><strong>Firmado por:</strong> <%= bodyFirma || 'N/A' %></span>
        </div>
        <div class="sv-audit-strip__item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          <span><strong>Fecha de firma:</strong> <%= bodyFechaFirma ? new Date(bodyFechaFirma).toLocaleString('es-MX') : 'N/A' %></span>
        </div>
        <div class="sv-audit-strip__item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
          </svg>
          <span><strong>Publicado en:</strong> <%= reporte.updated_at ? new Date(reporte.updated_at).toLocaleString('es-MX') : 'N/A' %></span>
        </div>
      </div>

      <!-- Datos Generales en grid 3 columnas -->
      <h2 class="sv-section-title">Datos Generales</h2>
      <div class="sv-data-grid">
        <div class="sv-data-grid__item">
          <span class="sv-data-grid__label">Planta</span>
          <span class="sv-data-grid__value"><%= cotizacion.planta || 'N/A' %></span>
        </div>
        <div class="sv-data-grid__item">
          <span class="sv-data-grid__label">Cliente</span>
          <span class="sv-data-grid__value"><%= cotizacion.cliente || 'N/A' %></span>
        </div>
        <div class="sv-data-grid__item">
          <span class="sv-data-grid__label">Número de parte</span>
          <span class="sv-data-grid__value sv-part-number"><%= cotizacion.numero_parte || 'N/A' %></span>
        </div>
        <div class="sv-data-grid__item">
          <span class="sv-data-grid__label">Nombre de parte</span>
          <span class="sv-data-grid__value"><%= cotizacion.nombre_parte || 'N/A' %></span>
        </div>
        <div class="sv-data-grid__item">
          <span class="sv-data-grid__label">Turno</span>
          <span class="sv-data-grid__value"><%= reporte.turno || 'N/A' %></span>
        </div>
        <div class="sv-data-grid__item">
          <span class="sv-data-grid__label">Tipo de servicio</span>
          <span class="sv-data-grid__value"><%= cotizacion.tipo_servicio || 'N/A' %></span>
        </div>
        <div class="sv-data-grid__item">
          <span class="sv-data-grid__label">Inspector</span>
          <span class="sv-data-grid__value"><%= reporte.nombre_inspector || 'N/A' %></span>
        </div>
        <div class="sv-data-grid__item">
          <span class="sv-data-grid__label">Estado</span>
          <span class="sv-data-grid__value">
            <span class="sv-badge sv-badge--success">PUBLICADO</span>
          </span>
        </div>
      </div>

      <!-- Tabla: Lotes inspeccionados (solo lectura) -->
      <h2 class="sv-section-title">
        Lotes Inspeccionados
        <span class="sv-readonly-badge">solo lectura</span>
      </h2>
      <div class="sv-table-wrapper sv-table-wrapper--scrollable">
        <table class="sv-table sv-table--readonly" aria-label="Lotes inspeccionados — solo lectura">
          <thead>
            <tr>
              <th scope="col">Lote</th>
              <th scope="col">Series</th>
              <th scope="col">Otro</th>
              <th scope="col">Total</th>
              <th scope="col">Buenas</th>
              <th scope="col">NG</th>
              <th scope="col">Defectos</th>
              <th scope="col">Validación</th>
            </tr>
          </thead>
          <tbody>
            <% items.forEach(function(item) { %>
              <tr>
                <td><%= item.lotes || '—' %></td>
                <td><%= item.series || '—' %></td>
                <td><%= item.otro || '—' %></td>
                <td><%= item.total %></td>
                <td><%= item.OK %></td>
                <td><%= item.NG %></td>
                <td>
                  <% if (item.incidencias && item.incidencias.length > 0) { %>
                    <%= item.incidencias.map(function(i) { return i.nombre + ' (' + i.cantidad + ')'; }).join(', ') %>
                  <% } else { %>
                    Sin defectos
                  <% } %>
                </td>
                <td>
                  <% if ((item.OK + item.NG) === item.total) { %>
                    <span class="sv-badge sv-badge--success">OK</span>
                  <% } else { %>
                    <span class="sv-badge sv-badge--danger">ERROR</span>
                  <% } %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

    </main>
  </div><!-- /sv-layout -->

  <script src="/scripts/supervisor/scripts_detalle_publicado.js"></script>

  <!-- Lógica del drawer hamburguesa (inline porque esta vista no carga scripts_bandeja.js) -->
  <script>
  (function () {
    var btn     = document.getElementById('sv-hamburger-btn');
    var sidebar = document.getElementById('sv-sidebar-nav');
    var overlay = document.getElementById('sv-sidebar-overlay');
    if (!btn) return;

    function openDrawer() {
      sidebar.classList.add('is-open');
      overlay.classList.add('is-visible');
      btn.setAttribute('aria-expanded', 'true');
    }
    function closeDrawer() {
      sidebar.classList.remove('is-open');
      overlay.classList.remove('is-visible');
      btn.setAttribute('aria-expanded', 'false');
    }
    btn.addEventListener('click', function () {
      sidebar.classList.contains('is-open') ? closeDrawer() : openDrawer();
    });
    overlay.addEventListener('click', closeDrawer);
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeDrawer();
    });
  }());
  </script>
</body>
</html>
