<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Detalle del Reporte | Quality Bolca</title>
  <link rel="stylesheet" href="/styles/supervisor/estilos_supervisor.css" />
  <meta name="csrf-token" content="<%= csrfToken %>">
</head>

<body>

  <!-- P-06: DETALLE DEL REPORTE + CHATBOT DE EDICIÓN -->

  <!-- Header -->
  <header class="sv-header">
    <!-- Botón hamburguesa: visible solo en móvil/tablet (≤768px) -->
    <button
      class="sv-hamburger"
      id="sv-hamburger-btn"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="sv-sidebar-nav"
    >
      <svg class="sv-hamburger__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="6"  x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>

    <div class="sv-header__brand">
      <img class="sv-header__logo" src="https://qualitybolca.com/assets/images/logo.png" alt="Quality Bolca"
        onerror="this.style.display='none'" />
    </div>
    <div class="sv-header__actions">
      <span class="sv-header__username">
        <%= supervisor.nombre %>
      </span>
      <a href="/bots/supervisor/bandeja" class="sv-btn sv-btn--ghost" aria-label="Volver a la bandeja">
        &larr; Volver a bandeja
      </a>
    </div>
  </header>

  <!-- Overlay oscuro: cubre el contenido al abrir el drawer en móvil -->
  <div class="sv-sidebar-overlay" id="sv-sidebar-overlay" aria-hidden="true"></div>

  <div class="sv-layout">

    <!-- Sidebar -->
    <nav class="sv-sidebar" id="sv-sidebar-nav" aria-label="Navegación principal">
      <div class="sv-sidebar__brand">
        <img src="https://qualitybolca.com/assets/images/logo.png" alt="Quality Bolca" onerror="this.style.display='none'" />
      </div>
      <ul class="sv-sidebar__list">
        <li>
          <a href="/bots/supervisor/bandeja" class="sv-sidebar__item sv-sidebar__item--active" aria-current="page">
            <svg class="sv-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <path
                d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            Bandeja
          </a>
        </li>
        <li>
          <a href="/bots/supervisor/historial" class="sv-sidebar__item">
            <svg class="sv-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <path
                d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
            Historial publicados
          </a>
        </li>
        <li>
          <button class="sv-sidebar__item">
            <svg class="sv-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            Mi perfil
          </button>
        </li>
      </ul>
    </nav>

    <!-- Contenido principal: split view -->
    <main class="sv-main sv-main--split">

      <!-- Panel izquierdo: detalle del reporte -->
      <section class="sv-detail-panel" aria-label="Detalle del reporte">
        <div class="sv-panel-header">
          <h2 class="sv-panel-title">Detalle del Reporte</h2>
          <p class="sv-panel-meta">
            <%= reporte.inspector_nombre || 'Inspector' %> ·
              <%= new Date(reporte.created_at).toLocaleDateString('es-MX') %>
                <%= reporte.turno %>
          </p>
        </div>

        <!-- Alerta de error de validación (oculta por defecto) -->
        <div class="sv-alert sv-alert--error hidden" id="alerta-validacion" role="alert">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
            <circle cx="12" cy="12" r="10" />
            <line x1="12" y1="8" x2="12" y2="12" />
            <line x1="12" y1="16" x2="12.01" y2="16" />
          </svg>
          Error de validación matemática: la suma de piezas buenas y NG no coincide con el total. Por favor verifique
          los datos antes de firmar.
        </div>

        <!-- Tabla: Datos Generales -->
        <h3 class="sv-section-title">Datos Generales</h3>
        <div class="sv-table-wrapper">
          <table class="sv-table sv-table--compact" aria-label="Datos generales del reporte">
            <tbody>
              <tr>
                <th scope="row">Planta</th>
                <td>
                  <%= cotizacion.planta || 'N/A' %>
                </td>
                <th scope="row">Cliente</th>
                <td>
                  <%= cotizacion.cliente || 'N/A' %>
                </td>
              </tr>
              <tr>
                <th scope="row">Número de parte</th>
                <td><span class="sv-part-number">
                    <%= cotizacion.numero_parte %>
                  </span></td>
                <th scope="row">Nombre de parte</th>
                <td>
                  <%= cotizacion.nombre_parte || 'N/A' %>
                </td>
              </tr>
              <tr>
                <th scope="row">Turno</th>
                <td>
                  <%= reporte.turno %>
                </td>
                <th scope="row">Tipo de servicio</th>
                <td>
                  <%= cotizacion.tipo_servicio || 'N/A' %>
                </td>
              </tr>
              <tr>
                <th scope="row">Cotización</th>
                <td>
                  <%= cotizacion.id || 'N/A' %>
                </td>
                <th scope="row">Inspector</th>
                <td>
                  <%= reporte.nombre_inspector || 'N/A' %>
                </td>
              </tr>
              <tr>
                <th scope="row">Estado</th>
                <td>
                  <% if (bodyStatus === 'pending') { %>
                    <span class="sv-badge sv-badge--warning">PENDIENTE</span>
                  <% } else if (bodyStatus === 'signed') { %>
                    <span class="sv-badge" style="background:#dbeafe;color:#1e40af;border:1px solid #93c5fd;">FIRMADO</span>
                  <% } else if (bodyStatus === 'published') { %>
                    <span class="sv-badge sv-badge--success">PUBLICADO</span>
                  <% } %>
                </td>
                <th scope="row">Firmado por</th>
                <td>
                  <% if (bodyFirma) { %>
                    <%= bodyFirma %>
                    <% if (bodyFechaFirma) { %>
                      <br><small style="color:#6b7280;font-size:0.75rem;">
                        <%= new Date(bodyFechaFirma).toLocaleString('es-MX') %>
                      </small>
                    <% } %>
                  <% } else { %>
                    —
                  <% } %>
                </td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Tabla: Lotes Inspeccionados -->
        <h3 class="sv-section-title">Lotes Inspeccionados</h3>
        <div class="sv-table-wrapper">
          <table class="sv-table" aria-label="Lotes inspeccionados">
            <thead>
              <tr>
                <th scope="col">Lote</th>
                <th scope="col">Series</th>
                <th scope="col">Otro</th>
                <th scope="col">Total</th>
                <th scope="col">Buenas</th>
                <th scope="col">NG</th>
                <th scope="col">Defectos</th>
                <th scope="col">Validación</th>
              </tr>
            </thead>
            <tbody>
              <% items.forEach(function(item) { %>
                <tr>
                  <td><%= item.lotes || '—' %></td>
                  <td><%= item.series || '—' %></td>
                  <td><%= item.otro || '—' %></td>
                  <td><%= item.total %></td>
                  <td><%= item.OK %></td>
                  <td><%= item.NG %></td>
                  <td>
                    <% if (item.incidencias && item.incidencias.length > 0) { %>
                      <%= item.incidencias.map(i => `${i.nombre} (${i.cantidad})`).join(', ') %>
                    <% } else { %>
                      Sin defectos
                    <% } %>
                  </td>
                  <td>
                    <% if ((item.OK + item.NG) === item.total) { %>
                      <span class="sv-badge sv-badge--success">OK</span>
                    <% } else { %>
                      <span class="sv-badge sv-badge--danger">ERROR</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <!-- Acciones del reporte -->
        <div class="sv-detail-actions">
          <button
            class="sv-btn sv-btn--primary"
            id="btn-firmar"
            onclick="firmarReporte()"
            <% if (bodyStatus !== 'pending') { %>disabled style="opacity:0.5"<% } %>
          >
            <% if (bodyStatus === 'pending') { %>Firmar Reporte<% } else { %>Firmado<% } %>
          </button>
          <button
            class="sv-btn sv-btn--success"
            id="btn-publicar"
            onclick="publicarReporte()"
            <% if (bodyStatus !== 'signed') { %>disabled aria-disabled="true"<% } %>
          >
            Publicar Reporte
          </button>
        </div>

      </section><!-- /sv-detail-panel -->

      <!-- Panel derecho: Chatbot de edición (drawer flotante) -->
      <aside class="sv-chat-panel" id="sv-chat-panel" aria-label="Chatbot de edición">
        <div class="sv-chat-header">
          <div class="sv-chat-header__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
              <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" />
            </svg>
          </div>
          <div>
            <h2 class="sv-chat-header__title">Chatbot de Edición</h2>
            <p class="sv-chat-header__subtitle">Asistente de revisión de reportes</p>
          </div>
          <button class="sv-chat-close" id="sv-chat-close" aria-label="Cerrar asistente">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
              <line x1="18" y1="6" x2="6" y2="18" />
              <line x1="6" y1="6" x2="18" y2="18" />
            </svg>
          </button>
        </div>

        <!-- Historial de mensajes -->
        <div class="sv-chat-messages" id="chat-messages" aria-live="polite" aria-label="Historial de mensajes">
          <div class="sv-chat-bubble sv-chat-bubble--system">
            <p>Hola María, he cargado el reporte de Juan Pérez del 10/04/2026 turno Vespertino. Puedo ayudarte a revisar
              los datos, identificar discrepancias o editar información. ¿En qué te puedo asistir?</p>
          </div>
          <div class="sv-chat-bubble sv-chat-bubble--system">
            <p>Los 3 lotes pasan la validación matemática. El total general es 3,630 piezas con 33 NG (0.91% de
              rechazo).</p>
          </div>
        </div>

        <!-- Selector de modo de entrada -->
        <div class="sv-chat-mode" role="group" aria-label="Modo de entrada">
          <button class="sv-chat-mode__btn sv-chat-mode__btn--active" id="modo-texto" onclick="setModoChat('texto')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
              <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" />
              <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" />
            </svg>
            Texto
          </button>
          <button class="sv-chat-mode__btn" id="modo-voz" onclick="setModoChat('voz')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
              <path d="M12 2a3 3 0 013 3v7a3 3 0 01-6 0V5a3 3 0 013-3z" />
              <path d="M19 10v2a7 7 0 01-14 0v-2" />
              <line x1="12" y1="19" x2="12" y2="22" />
            </svg>
            Voz
          </button>
        </div>

        <!-- Input de texto -->
        <div class="sv-chat-input-area">
          <label for="chat-input" class="sr-only">Escribe un mensaje</label>
          <input type="text" id="chat-input" class="sv-chat-input" placeholder="Escribe tu consulta o instrucción..."
            autocomplete="off" aria-label="Mensaje para el chatbot" />
          <button class="sv-btn sv-btn--primary sv-chat-send" id="btn-chat-send" onclick="enviarMensajeChat()"
            aria-label="Enviar mensaje">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
              stroke-linejoin="round" width="18" height="18">
              <line x1="22" y1="2" x2="11" y2="13" />
              <polygon points="22 2 15 22 11 13 2 9 22 2" />
            </svg>
          </button>
        </div>

      </aside><!-- /sv-chat-panel -->

    </main>
  </div><!-- /sv-layout -->

  <!-- FAB: botón flotante para abrir el asistente -->
  <button
    class="sv-chat-fab"
    id="sv-chat-fab"
    aria-label="Abrir asistente de edición"
    aria-expanded="false"
    aria-controls="sv-chat-panel"
  >
    <!-- Ícono chat (visible cuando el drawer está cerrado) -->
    <span class="sv-chat-fab__icon-open" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
        stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
        <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" />
      </svg>
    </span>
    <!-- Ícono X (visible cuando el drawer está abierto) -->
    <span class="sv-chat-fab__icon-close" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
        stroke-linecap="round" stroke-linejoin="round" width="22" height="22">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </span>
  </button>

  <!-- Overlay oscuro detrás del drawer -->
  <div class="sv-chat-overlay" id="sv-chat-overlay" aria-hidden="true"></div>

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="/scripts/supervisor/scripts_detalle_reporte.js"></script>
  <script>
    window.REPORTE_ID     = <%= reporte.id %>;
    window.BODY_ID        = <%= bodyId %>;
    window.REPORTE_STATUS = '<%= bodyStatus %>';
  </script>

  <!-- Lógica del drawer hamburguesa (inline porque esta vista no carga scripts_bandeja.js) -->
  <script>
  (function () {
    var btn     = document.getElementById('sv-hamburger-btn');
    var sidebar = document.getElementById('sv-sidebar-nav');
    var overlay = document.getElementById('sv-sidebar-overlay');
    if (!btn) return;

    function openDrawer() {
      sidebar.classList.add('is-open');
      overlay.classList.add('is-visible');
      btn.setAttribute('aria-expanded', 'true');
    }
    function closeDrawer() {
      sidebar.classList.remove('is-open');
      overlay.classList.remove('is-visible');
      btn.setAttribute('aria-expanded', 'false');
    }
    btn.addEventListener('click', function () {
      sidebar.classList.contains('is-open') ? closeDrawer() : openDrawer();
    });
    overlay.addEventListener('click', closeDrawer);
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeDrawer();
    });
  }());
  </script>
</body>

</html>