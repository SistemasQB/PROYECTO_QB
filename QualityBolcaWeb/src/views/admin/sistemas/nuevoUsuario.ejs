<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registrar nuevo usuario</title>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link rel="stylesheet" href="/styles/sistemas/nuevoUsuario.css">
</head>

<body>
    <header class="module-header">
        <div class="header-content">
            <h1>Registrar Nuevo Usuario</h1>
        </div>
    </header>

    <main class="main-content">
        <div class="form-container">
            <div class="form-header">
                <h2>Crear Nuevo Usuario</h2>
                <p>Ingrese los datos del nuevo usuario.</p>
            </div>
        
            <form id="userForm" class="user-form">
                <div class="form-group">
                    <label>Nombre(s) *</label>
                    <input type="text" id="nombre" name="nombres" required>
                </div>

                <div class="form-group">
                    <label>Apellido Paterno *</label>
                    <input type="text" id="apellidopaterno" name="apellidopaterno" required>
                </div>

                <div class="form-group">
                    <label>Apellido Materno *</label>
                    <input type="text" id="apellidomaterno" name="apellidomaterno" required>
                </div>

                <div class="form-group">
                    <label>Nombre Largo *</label>
                    <input type="text" id="nombrelargo" name="nombrelargo" readonly required>
                </div>
                <div class="form-group">
                    <label>Correo electónico corporativo *</label>
                    <input type="email" id="correo" name="correo" required>
                </div>

                <div class="form-group">
                    <label for="departamento">Departamento *</label>
                    <select id="departamento" name="departamento" required>
                        <option value="">Seleccione un departamento</option>
                        <% departamentos.forEach(dep=> { %>
                            <option value="<%= dep.iddepartamento %>">
                                <%= dep.descripcion %>
                            </option>
                            <% }) %>
                    </select>
                </div>

                <div class="form-group">
                    <label for="puesto">Puesto *</label>
                    <select id="puesto" name="puesto" required>
                        <option value="">Seleccione un puesto</option>
                        <% puestos.forEach(p=> { %>
                            <option value="<%= p.idpuesto %>">
                                <%= p.descripcion %>
                            </option>
                            <% }) %>
                    </select>
                </div>

                <div class="form-group">
                    <label class="switch-label">
                        <span>¿Es becario?</span>

                        <label class="switch">
                            <input type="checkbox" id="esBecario" name="esBecario">
                            <span class="slider"></span>
                        </label>

                    </label>
                </div>

                <div class="form-actions">
                    <button type="button" class="btn btn-primary" id="btnEnvio">
                        <span class="btn-text">Crear Usuario</span>
                    </button>
                    <button type="reset" class="btn btn-secondary">
                        Limpiar Formulario
                    </button>
                </div>

            </form>
        </div>
    </main>


    <script src="/scripts/sistemas/nuevoUsuario.js"></script>

</body>

</html>