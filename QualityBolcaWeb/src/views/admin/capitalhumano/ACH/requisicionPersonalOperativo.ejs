<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="<%= token %>">
  <title>Requisición de Personal Operativo — Quality Bolca</title>
  <link rel="icon" type="image/png" href="/img/favicon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@400,0&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles/capitalhumano/estilos_requisicionPersonalOperativo.css">
</head>
<body>

<!-- TOAST -->
<div class="toast" id="toast">
  <span class="material-symbols-outlined" id="toastIcon">check_circle</span>
  <span id="toastMsg">Mensaje</span>
</div>

<div class="layout">

  <!-- SIDEBAR -->
  <div class="sidebar-overlay" id="sidebarOverlay"></div>
  <aside class="sidebar" id="sidebar">

    <div class="logo-container">
      <div class="logo-icon">
        <span class="material-symbols-outlined">groups</span>
      </div>
      <span>Capital Humano</span>
    </div>

    <div class="profile-section">
      <div class="avatar" id="avatarUsuario"></div>
      <div class="profile-name"><%= datosUsuario.nombrelargo %></div>
      <div class="profile-role"><%= datosUsuario.puesto || '' %></div>
      <div class="profile-dept"><%= datosUsuario.departamento || '' %></div>
    </div>

    <ul class="nav-menu">
      <a href="/atraccion/requisicion-personal" class="nav-item active">
        <span class="material-symbols-outlined">post_add</span>
        Nueva Requisición
      </a>
    </ul>

  </aside>

  <!-- MAIN -->
  <main class="main">
    <div class="content-wrapper">

      <header class="page-header">
        <div>
          <h2 class="page-title">Requisición de Personal Operativo</h2>
          <p class="page-sub">Complete los campos para enviar la solicitud al equipo de Atracción.</p>
        </div>
        <button class="btn btn--primary" id="btnEnviarTop">
          <span class="material-symbols-outlined">send</span>
          Enviar Requisición
        </button>
      </header>

      <form id="req-form" novalidate autocomplete="off">
        <div class="form-sections">

          <!-- SECCIÓN 1: INFORMACIÓN DE LA REQUISICIÓN -->
          <section class="card">
            <div class="card-header">
              <span class="material-symbols-outlined">location_on</span>
              <h3 class="card-title">Información de la Requisición</h3>
            </div>

            <div class="grid-2">
              <div class="field" id="f-region">
                <label class="field-label">Región <span class="req">*</span></label>
                <select class="input" id="region" name="region" aria-required="true">
                  <option value="">Cargando...</option>
                </select>
                <span class="field-error" id="err-region">Selecciona una región.</span>
              </div>

              <div class="field" id="f-planta">
                <label class="field-label">Planta <span class="req">*</span></label>
                <select class="input" id="planta" name="planta" disabled aria-required="true">
                  <option value="">Primero selecciona una región</option>
                </select>
                <span class="field-error" id="err-planta">Selecciona una planta.</span>
              </div>
            </div>

            <div class="field" id="f-cantidadPersonal" style="max-width:240px; margin-top:18px;">
              <label class="field-label">Cantidad de personal <span class="req">*</span></label>
              <input class="input" type="number" id="cantidadPersonal" name="cantidadPersonal" min="1" max="500" placeholder="Ej. 10">
              <span class="field-error" id="err-cantidadPersonal">Ingresa un valor entre 1 y 500.</span>
            </div>

            <div class="field" id="f-caracteristicas" style="margin-top:18px;">
              <label class="field-label">Características del puesto <span class="req">*</span></label>
              <textarea class="input" id="caracteristicas" name="caracteristicas" placeholder="Describe las actividades, requisitos físicos, técnicos o de experiencia del puesto..."></textarea>
              <span class="field-error" id="err-caracteristicas">Describe las características del puesto (mínimo 10 caracteres).</span>
            </div>
          </section>

          <!-- SECCIÓN 2: PERFIL DEL CANDIDATO -->
          <section class="card">
            <div class="card-header">
              <span class="material-symbols-outlined">person_search</span>
              <h3 class="card-title">Perfil del Candidato</h3>
            </div>

            <div class="grid-2">
              <div class="field" id="f-tipoContratacion">
                <label class="field-label">Tipo de contratación <span class="req">*</span></label>
                <select class="input" id="tipoContratacion" name="tipoContratacion">
                  <option value="">-- Selecciona --</option>
                  <option value="Locales">Locales</option>
                  <option value="CDR">CDR (Cambios de residencia)</option>
                </select>
                <span class="field-error" id="err-tipoContratacion">Selecciona el tipo de contratación.</span>
              </div>

              <div class="field" id="f-sexo">
                <label class="field-label">Sexo <span class="req">*</span></label>
                <select class="input" id="sexo" name="sexo">
                  <option value="">-- Selecciona --</option>
                  <option value="Masculino">Masculino</option>
                  <option value="Femenino">Femenino</option>
                  <option value="Indistinto">Indistinto</option>
                </select>
                <span class="field-error" id="err-sexo">Selecciona el sexo requerido.</span>
              </div>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:16px; margin-top:18px;">
              <div class="field">
                <label class="field-label">Locales</label>
                <select class="input" id="locales" name="locales">
                  <option value="NO" selected>NO</option>
                  <option value="SI">SI</option>
                </select>
              </div>
              <div class="field">
                <label class="field-label">CDR (Cambio de residencia)</label>
                <select class="input" id="cdr" name="cdr">
                  <option value="NO" selected>NO</option>
                  <option value="SI">SI</option>
                </select>
              </div>
              <div class="field">
                <label class="field-label">Antidoping</label>
                <select class="input" id="antidoping" name="antidoping">
                  <option value="NO" selected>NO</option>
                  <option value="SI">SI</option>
                </select>
              </div>
            </div>

            <hr class="divider">

            <div class="field" id="f-edadRango" style="max-width:260px;">
              <label class="field-label">Rango de edad <span class="req">*</span></label>
              <div class="age-wrap" role="group" aria-label="Rango de edad">
                <div class="age-group">
                  <span class="age-sublabel">Mínima</span>
                  <input type="number" id="edadMin" name="edadMin" min="16" max="70" value="18" aria-label="Edad mínima">
                </div>
                <div class="age-sep">—</div>
                <div class="age-group">
                  <span class="age-sublabel">Máxima</span>
                  <input type="number" id="edadMax" name="edadMax" min="16" max="70" value="45" aria-label="Edad máxima">
                </div>
              </div>
              <span class="field-error" id="err-edadRango">Verifica el rango: mínima 16, máxima 70, y mínima menor que máxima.</span>
            </div>
          </section>

          <!-- SECCIÓN 3: CONDICIONES LABORALES -->
          <section class="card">
            <div class="card-header">
              <span class="material-symbols-outlined">settings</span>
              <h3 class="card-title">Condiciones Laborales</h3>
            </div>

            <div class="grid-2">
              <div class="field" id="f-rolarTurno">
                <label class="field-label">Rolar turno <span class="req">*</span></label>
                <select class="input" id="rolarTurno" name="rolarTurno">
                  <option value="">-- Selecciona --</option>
                  <option value="Sí">Sí</option>
                  <option value="No">No</option>
                </select>
                <span class="field-error" id="err-rolarTurno">Indica si se requiere rolar turno.</span>
              </div>

              <div class="field" id="f-rolarTurnoEspecificacion">
                <label class="field-label">Especificación del turno <span class="req">*</span></label>
                <input class="input" type="text" id="rolarTurnoEspecificacion" name="rolarTurnoEspecificacion" placeholder="Ej. Solo turno nocturno, rotación semanal...">
                <span class="field-error" id="err-rolarEspec">Especifica el tipo de turno requerido.</span>
              </div>
            </div>

            <hr class="divider">

            <div class="field" id="f-eppEspecial">
              <label class="field-label">EPP Especial requerido <span class="req">*</span></label>
              <textarea class="input" id="eppEspecial" name="eppEspecial" placeholder="Describe el equipo de protección personal especial: casco, botas dieléctricas, guantes de corte, etc..."></textarea>
              <span class="field-error" id="err-eppEspecial">Describe el EPP especial requerido (mínimo 5 caracteres).</span>
            </div>

            <hr class="divider">

            <div class="field" id="f-diasDescanso">
              <label class="field-label">Días de descanso <span class="req">*</span></label>
              <p class="hint">Selecciona de 1 a 5 días.</p>
              <div class="days-group" id="diasDescansoGroup" role="group" aria-label="Días de descanso">
                <label class="day-pill" title="Lunes"><input type="checkbox" name="diasDescanso" value="Lunes"> L</label>
                <label class="day-pill" title="Martes"><input type="checkbox" name="diasDescanso" value="Martes"> M</label>
                <label class="day-pill" title="Miércoles"><input type="checkbox" name="diasDescanso" value="Miércoles"> X</label>
                <label class="day-pill" title="Jueves"><input type="checkbox" name="diasDescanso" value="Jueves"> J</label>
                <label class="day-pill" title="Viernes"><input type="checkbox" name="diasDescanso" value="Viernes"> V</label>
                <label class="day-pill" title="Sábado"><input type="checkbox" name="diasDescanso" value="Sábado"> S</label>
                <label class="day-pill" title="Domingo"><input type="checkbox" name="diasDescanso" value="Domingo"> D</label>
              </div>
              <span class="field-error" id="err-diasDescanso">Selecciona entre 1 y 5 días de descanso.</span>
            </div>
          </section>

          <!-- SECCIÓN 4: PROTOCOLO DE INGRESO -->
          <section class="card">
            <div class="card-header">
              <span class="material-symbols-outlined">assignment</span>
              <h3 class="card-title">Protocolo de Ingreso</h3>
            </div>

            <div class="field" id="f-protocoloIngreso" style="max-width:240px;">
              <label class="field-label">Protocolo de ingreso <span class="req">*</span></label>
              <select class="input" id="protocoloIngreso" name="protocoloIngreso">
                <option value="">-- Selecciona --</option>
                <option value="Sí">Sí</option>
                <option value="No">No</option>
              </select>
              <span class="field-error" id="err-protocoloIngreso">Indica si se requiere protocolo de ingreso.</span>
            </div>

            <hr class="divider">

            <div class="field" id="f-diaProtocolo">
              <label class="field-label">Día de protocolo <span class="req">*</span></label>
              <p class="hint" style="font-style:normal; font-weight:500; color:var(--slate-500);">
                En caso de no ser mencionado se deberá pagar el tiempo que el personal esté en espera.
              </p>
              <div class="days-group" id="diaProtocoloGroup" role="group" aria-label="Días de protocolo">
                <label class="day-pill" title="Lunes"><input type="checkbox" name="diaProtocolo" value="Lunes"> L</label>
                <label class="day-pill" title="Martes"><input type="checkbox" name="diaProtocolo" value="Martes"> M</label>
                <label class="day-pill" title="Miércoles"><input type="checkbox" name="diaProtocolo" value="Miércoles"> X</label>
                <label class="day-pill" title="Jueves"><input type="checkbox" name="diaProtocolo" value="Jueves"> J</label>
                <label class="day-pill" title="Viernes"><input type="checkbox" name="diaProtocolo" value="Viernes"> V</label>
                <label class="day-pill" title="Sábado"><input type="checkbox" name="diaProtocolo" value="Sábado"> S</label>
                <label class="day-pill" title="Domingo"><input type="checkbox" name="diaProtocolo" value="Domingo"> D</label>
              </div>
              <span class="field-error" id="err-diaProtocolo">Selecciona al menos un día de protocolo.</span>
            </div>
          </section>

        </div><!-- /form-sections -->

        <footer class="page-footer">
          <button type="button" class="btn btn--ghost" id="btnLimpiar">
            <span class="material-symbols-outlined">restart_alt</span>
            Limpiar
          </button>
          <button type="submit" class="btn btn--primary" id="btnEnviarBottom">
            <span class="material-symbols-outlined">send</span>
            <span id="btnEnviarText">Enviar Requisición</span>
          </button>
        </footer>

      </form>

    </div><!-- /content-wrapper -->
  </main>

</div><!-- /layout -->

<script>
(function () {
  'use strict';

  /* ─── CSRF ───────────────────────────────────────────────── */
  function getCsrf() {
    const m = document.querySelector('meta[name="csrf-token"]');
    return m ? m.getAttribute('content') : '';
  }

  /* ─── AVATAR ─────────────────────────────────────────────── */
  (function initAvatar() {
    const el = document.getElementById('avatarUsuario');
    if (!el) return;
    const nombre = '<%= datosUsuario.nombrelargo %>';
    const partes  = nombre.trim().split(' ');
    const iniciales = (partes[0]?.[0] || '') + (partes[1]?.[0] || '');
    el.textContent = iniciales.toUpperCase();
    const colores = ['#137fec','#0e6fd4','#0284c7','#0369a1','#075985'];
    el.style.background = colores[nombre.charCodeAt(0) % colores.length];
  })();

  /* ─── TOAST ──────────────────────────────────────────────── */
  let toastTimer;
  function showToast(type, msg) {
    const el   = document.getElementById('toast');
    const icon = document.getElementById('toastIcon');
    const text = document.getElementById('toastMsg');
    clearTimeout(toastTimer);
    el.className = 'toast';
    void el.offsetWidth;
    icon.textContent = type === 'success' ? 'check_circle' : 'error';
    text.textContent = msg;
    el.classList.add('is-visible', type === 'success' ? 'toast--success' : 'toast--error');
    toastTimer = setTimeout(() => el.classList.remove('is-visible'), 4500);
  }

  /* ─── ERROR EN CAMPO ─────────────────────────────────────── */
  function setError(fieldId, hasError) {
    const field = document.getElementById(fieldId);
    if (!field) return;
    field.classList.toggle('has-error', hasError);
    if (hasError) {
      const el = field.querySelector('.input, .age-wrap, .days-group');
      if (el) {
        el.classList.remove('shake');
        void el.offsetWidth;
        el.classList.add('shake');
        el.addEventListener('animationend', () => el.classList.remove('shake'), { once: true });
      }
    }
  }

  /* ─── CATÁLOGOS ──────────────────────────────────────────── */
  async function fetchCatalogo(catalogo) {
    const res = await fetch('/atraccion/catalogos', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': getCsrf() },
      body: JSON.stringify({ catalogo })
    });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const json = await res.json();
    if (!json.ok) throw new Error(`Error cargando catálogo "${catalogo}"`);
    return json.data;
  }

  function poblarSelect(id, items, labelField, placeholder) {
    const sel = document.getElementById(id);
    if (!sel) return;
    sel.innerHTML = `<option value="">${placeholder}</option>`;
    items.forEach(item => {
      const opt = document.createElement('option');
      opt.value       = item.id;
      opt.textContent = item[labelField];
      sel.appendChild(opt);
    });
  }

  let todasLasPlantas = [];

  async function cargarCatalogos() {
    const selRegion = document.getElementById('region');
    const selPlanta = document.getElementById('planta');
    selRegion.innerHTML = '<option value="">Cargando...</option>';
    try {
      const [regiones, plantas] = await Promise.all([
        fetchCatalogo('regiones'),
        fetchCatalogo('plantas')
      ]);
      poblarSelect('region', regiones, 'nombre_region', '-- Selecciona región --');
      todasLasPlantas = plantas.filter(p => p.activo !== false);
      selPlanta.innerHTML = '<option value="">Primero selecciona una región</option>';
      selPlanta.disabled  = true;
    } catch (err) {
      console.error('[ACH] Error cargando catálogos:', err);
      selRegion.innerHTML = '<option value="">Error al cargar — recarga la página</option>';
    }
  }

  document.getElementById('region').addEventListener('change', function () {
    const selPlanta = document.getElementById('planta');
    if (this.value) {
      selPlanta.disabled = false;
      poblarSelect('planta', todasLasPlantas, 'nombre_planta', '-- Selecciona planta --');
      setError('f-region', false);
    } else {
      selPlanta.disabled  = true;
      selPlanta.innerHTML = '<option value="">Primero selecciona una región</option>';
    }
  });

  /* ─── PILLS DE DÍAS ──────────────────────────────────────── */
  function initDayPills(groupId, maxSel) {
    const group = document.getElementById(groupId);
    if (!group) return;
    group.addEventListener('click', function (e) {
      const pill = e.target.closest('.day-pill');
      if (!pill || pill.classList.contains('pill-disabled')) return;
      const cb = pill.querySelector('input[type=checkbox]');
      if (!cb) return;
      const willCheck = !cb.checked;
      if (willCheck && maxSel !== null) {
        const selected = group.querySelectorAll('input:checked').length;
        if (selected >= maxSel) return;
      }
      cb.checked = willCheck;
      pill.classList.toggle('sel', willCheck);
      if (maxSel !== null) syncPillDisabled(group, maxSel);
      const fId = group.closest('.field')?.id;
      if (fId) setError(fId, false);
    });
  }

  function syncPillDisabled(group, maxSel) {
    const pills    = group.querySelectorAll('.day-pill');
    const selected = group.querySelectorAll('input:checked').length;
    const full     = selected >= maxSel;
    pills.forEach(pill => {
      const checked = pill.querySelector('input')?.checked;
      pill.classList.toggle('pill-disabled', full && !checked);
    });
  }

  initDayPills('diasDescansoGroup', 5);
  initDayPills('diaProtocoloGroup', null);

  /* ─── VALIDACIÓN ─────────────────────────────────────────── */
  function validar() {
    let ok = true;
    let first = null;

    function mark(id, error) {
      setError(id, error);
      if (error && !first) first = id;
      if (error) ok = false;
    }

    const region          = document.getElementById('region').value;
    const planta          = document.getElementById('planta').value;
    const cantidad        = Number(document.getElementById('cantidadPersonal').value);
    const caracteristicas = document.getElementById('caracteristicas').value.trim();
    const tipoContr       = document.getElementById('tipoContratacion').value;
    const sexo            = document.getElementById('sexo').value;
    const edadMin         = Number(document.getElementById('edadMin').value);
    const edadMax         = Number(document.getElementById('edadMax').value);
    const rolarTurno      = document.getElementById('rolarTurno').value;
    const rolarEspec      = document.getElementById('rolarTurnoEspecificacion').value.trim();
    const epp             = document.getElementById('eppEspecial').value.trim();
    const diasDesc        = [...document.querySelectorAll('input[name="diasDescanso"]:checked')];
    const protocolo       = document.getElementById('protocoloIngreso').value;
    const diasProt        = [...document.querySelectorAll('input[name="diaProtocolo"]:checked')];

    mark('f-region',                  !region);
    mark('f-planta',                  !planta);
    mark('f-cantidadPersonal',        !cantidad || cantidad < 1 || cantidad > 500);
    mark('f-caracteristicas',         !caracteristicas || caracteristicas.length < 10);
    mark('f-tipoContratacion',        !tipoContr);
    mark('f-sexo',                    !sexo);
    mark('f-edadRango',               !edadMin || !edadMax || edadMin < 16 || edadMax > 70 || edadMin >= edadMax);
    mark('f-rolarTurno',              !rolarTurno);
    mark('f-rolarTurnoEspecificacion',!rolarEspec);
    mark('f-eppEspecial',             !epp || epp.length < 5);
    mark('f-diasDescanso',            diasDesc.length < 1 || diasDesc.length > 5);
    mark('f-protocoloIngreso',        !protocolo);
    mark('f-diaProtocolo',            diasProt.length < 1);

    return { ok, first };
  }

  /* ─── ENVÍO ──────────────────────────────────────────────── */
  async function enviar(e) {
    e.preventDefault();
    const { ok, first } = validar();
    if (!ok) {
      if (first) document.getElementById(first)?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }

    const payload = {
      id_region:            document.getElementById('region').value,
      id_planta:            document.getElementById('planta').value,
      cantidad_personal:    Number(document.getElementById('cantidadPersonal').value),
      caracteristicas:      document.getElementById('caracteristicas').value.trim(),
      tipo_contratacion:    document.getElementById('tipoContratacion').value,
      sexo:                 document.getElementById('sexo').value,
      edad_min:             Number(document.getElementById('edadMin').value),
      edad_max:             Number(document.getElementById('edadMax').value),
      rolar_turno:          document.getElementById('rolarTurno').value,
      rolar_especificacion: document.getElementById('rolarTurnoEspecificacion').value.trim() || null,
      epp_especial:         document.getElementById('eppEspecial').value.trim(),
      dias_descanso:        [...document.querySelectorAll('input[name="diasDescanso"]:checked')].map(i => i.value),
      protocolo_ingreso:    document.getElementById('protocoloIngreso').value,
      dias_protocolo:       [...document.querySelectorAll('input[name="diaProtocolo"]:checked')].map(i => i.value),
      locales:              document.getElementById('locales').value,
      cdr:                  document.getElementById('cdr').value,
      antidoping:           document.getElementById('antidoping').value,
    };

    const btn  = document.getElementById('btnEnviarBottom');
    const text = document.getElementById('btnEnviarText');
    const btnTop = document.getElementById('btnEnviarTop');
    btn.disabled = btnTop.disabled = true;
    text.textContent = 'Enviando...';

    try {
      const res  = await fetch('/atraccion/requisicion-personal', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': getCsrf() },
        body: JSON.stringify(payload)
      });
      const data = await res.json();

      if (res.ok && data.ok) {
        showToast('success', data.mensaje || 'Requisición enviada correctamente.');
        limpiar();
      } else {
        showToast('error', data.mensaje || 'No se pudo registrar la requisición.');
      }
    } catch (err) {
      console.error('[ACH]', err);
      showToast('error', 'Error de conexión. Verifica tu red e intenta nuevamente.');
    } finally {
      btn.disabled = btnTop.disabled = false;
      text.textContent = 'Enviar Requisición';
    }
  }

  /* ─── LIMPIAR ────────────────────────────────────────────── */
  function limpiar() {
    document.getElementById('req-form').reset();
    document.querySelectorAll('.field.has-error').forEach(f => f.classList.remove('has-error'));
    document.querySelectorAll('.day-pill.sel').forEach(p => p.classList.remove('sel', 'pill-disabled'));
    const selPlanta = document.getElementById('planta');
    selPlanta.disabled  = true;
    selPlanta.innerHTML = '<option value="">Primero selecciona una región</option>';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  /* ─── INIT ───────────────────────────────────────────────── */
  document.addEventListener('DOMContentLoaded', function () {
    cargarCatalogos();
    document.getElementById('req-form').addEventListener('submit', enviar);
    document.getElementById('btnEnviarTop').addEventListener('click', () => document.getElementById('req-form').requestSubmit());
    document.getElementById('btnLimpiar').addEventListener('click', limpiar);
  });

})();
</script>

</body>
</html>
