<!-- ════════════════════════════════════════════════════════════
     LÓGICA JS — IIFE para evitar contaminar namespace global
     ════════════════════════════════════════════════════════════ -->
<script>
(function () {
  'use strict';

  /* ─── UTILITARIOS ───────────────────────────────────────── */

  /** Lee el CSRF token del meta tag inyectado por EJS */
  function getCsrfToken() {
    const meta = document.querySelector('meta[name="csrf-token"]');
    return meta ? meta.getAttribute('content') : '';
  }

  /**
   * Muestra/oculta un campo condicional con animación max-height.
   * Reutiliza el patrón .cond / .cond.open del proyecto QB.
   */
  function toggleCond(id, show) {
    const el = document.getElementById(id);
    if (!el) return;
    el.classList.toggle('open', show);
  }

  /** Marca un campo como error y retorna false para encadenar validaciones */
  function setError(fieldId, show) {
    const field = document.getElementById(fieldId);
    if (!field) return;
    field.classList.toggle('has-error', show);
    if (show) {
      /* Sacude el campo para llamar la atención del usuario */
      const input = field.querySelector('input, select, textarea, .age-range-wrap, .days-group');
      if (input) {
        input.classList.remove('shake');
        /* Forzar reflow para reiniciar la animación si ya estaba activa */
        void input.offsetWidth;
        input.classList.add('shake');
        input.addEventListener('animationend', () => input.classList.remove('shake'), { once: true });
      }
    }
  }

  /* ─── FECHA EN HEADER ────────────────────────────────────── */
  (function renderHeaderDate() {
    const el = document.getElementById('hdr-date');
    if (!el) return;
    const now = new Date();
    /* Formato: "lunes, 28 de abril de 2026" */
    el.textContent = now.toLocaleDateString('es-MX', {
      weekday: 'long',
      year:    'numeric',
      month:   'long',
      day:     'numeric'
    });
  })();

  /* ─── CARGA DE CATÁLOGOS ─────────────────────────────────── */

  /**
   * Realiza un fetch POST al endpoint de catálogos QB.
   * El endpoint responde: { ok: bool, data: [...] }
   */
  async function fetchCatalogo(catalogo) {
    const res = await fetch('/capitalhumano/catalogos', {
      method:  'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': getCsrfToken()
      },
      body: JSON.stringify({ catalogo })
    });
    if (!res.ok) throw new Error(`HTTP ${res.status} al cargar catálogo "${catalogo}"`);
    const json = await res.json();
    if (!json.ok) throw new Error(`Error del servidor al cargar catálogo "${catalogo}"`);
    return json.data;
  }

  /**
   * Pobla un <select> con un array de objetos.
   * @param {string} selectId - ID del elemento <select>
   * @param {Array}  items    - Array de { id, label }
   * @param {string} placeholder - Texto de la opción vacía
   */
  function poblarSelect(selectId, items, placeholder) {
    const sel = document.getElementById(selectId);
    if (!sel) return;
    sel.innerHTML = `<option value="">${placeholder}</option>`;
    items.forEach(item => {
      const opt = document.createElement('option');
      opt.value       = item.id;
      opt.textContent = item.label;
      sel.appendChild(opt);
    });
  }

  /**
   * Carga regiones y plantas en paralelo al abrir la vista.
   * La planta permanece deshabilitada hasta que el usuario elija región.
   */
  async function cargarCatalogos() {
    const selRegion = document.getElementById('region');
    const selPlanta = document.getElementById('planta');

    /* Estado de carga inicial */
    selRegion.innerHTML = '<option value="">Cargando...</option>';
    selPlanta.innerHTML = '<option value="">Cargando plantas...</option>';

    try {
      /* Paralelo: ahorra ~200-400ms respecto a llamadas secuenciales */
      const [regiones, plantas] = await Promise.all([
        fetchCatalogo('regiones'),
        fetchCatalogo('plantas')
      ]);

      /* Poblar regiones */
      poblarSelect('region', regiones.map(r => ({ id: r.id, label: r.nombre_region })), '-- Selecciona región --');

      /* Guardar plantas en closure para usarlas al cambiar región */
      todasLasPlantas = plantas
        .filter(p => p.activo !== false)
        .map(p => ({ id: p.id, label: p.nombre_planta }));

      /* Planta: esperar a que el usuario seleccione región */
      selPlanta.innerHTML = '<option value="">Primero selecciona una región</option>';
      selPlanta.disabled  = true;

    } catch (err) {
      console.error('[ACH] Error cargando catálogos:', err);
      selRegion.innerHTML = '<option value="">Error al cargar — recarga la página</option>';
      selPlanta.innerHTML = '<option value="">No disponible</option>';
    }
  }

  /* Array de plantas cargado al inicio, reutilizado en el evento change de región */
  let todasLasPlantas = [];

  /* Cuando el usuario selecciona región, habilitar el select de planta */
  document.getElementById('region').addEventListener('change', function () {
    const selPlanta = document.getElementById('planta');
    if (this.value) {
      /* Habilitar y cargar todas las plantas (no hay filtro por región en el modelo) */
      selPlanta.disabled = false;
      poblarSelect('planta', todasLasPlantas, '-- Selecciona planta --');
      /* Limpiar error si lo había */
      setError('f-region', false);
    } else {
      selPlanta.disabled  = true;
      selPlanta.innerHTML = '<option value="">Primero selecciona una región</option>';
    }
  });

  /* ─── CAMPO CONDICIONAL: ROLAR TURNO ─────────────────────── */
  document.getElementById('rolarTurno').addEventListener('change', function () {
    const mostrar = this.value === 'Especifique';
    toggleCond('cond-rolar', mostrar);

    /* Limpiar el campo de especificación si se oculta */
    if (!mostrar) {
      const input = document.getElementById('rolarTurnoEspecificacion');
      if (input) input.value = '';
      setError('f-rolarTurnoEspecificacion', false);
    }
  });

  /* ─── SISTEMA DE PILLS DE DÍAS ───────────────────────────── */

  /**
   * Inicializa el comportamiento click de las pills de días.
   * @param {string} groupId    - ID del contenedor .days-group
   * @param {number|null} maxSel - Límite de selección (null = sin límite)
   */
  function initDayPills(groupId, maxSel) {
    const group = document.getElementById(groupId);
    if (!group) return;

    group.addEventListener('click', function (e) {
      /* Delegación al label.day-pill más cercano */
      const pill = e.target.closest('.day-pill');
      if (!pill || pill.classList.contains('disabled')) return;

      const checkbox = pill.querySelector('input[type=checkbox]');
      if (!checkbox) return;

      /* Determinar si va a quedar seleccionado */
      const willBeChecked = !checkbox.checked;

      if (willBeChecked && maxSel !== null) {
        /* Verificar si ya se alcanzó el límite antes de marcar */
        const selected = group.querySelectorAll('input[type=checkbox]:checked').length;
        if (selected >= maxSel) return; /* No hacer nada — límite alcanzado */
      }

      /* Actualizar checkbox y clase visual */
      checkbox.checked = willBeChecked;
      pill.classList.toggle('sel', willBeChecked);

      /* Después de cambiar, recalcular cuáles deben deshabilitarse */
      if (maxSel !== null) actualizarEstadoPills(group, maxSel);

      /* Limpiar error del grupo si el usuario seleccionó algo */
      const fieldId = group.closest('.field')?.id;
      if (fieldId) setError(fieldId, false);
    });
  }

  /**
   * Cuando se alcanza el límite máximo de días, deshabilita las pills
   * no seleccionadas para dar feedback visual claro.
   */
  function actualizarEstadoPills(group, maxSel) {
    const pills    = group.querySelectorAll('.day-pill');
    const selected = group.querySelectorAll('input[type=checkbox]:checked').length;
    const limitado = selected >= maxSel;

    pills.forEach(pill => {
      const isChecked = pill.querySelector('input[type=checkbox]')?.checked;
      if (limitado && !isChecked) {
        /* Deshabilitar pills no seleccionadas */
        pill.classList.add('disabled');
      } else {
        pill.classList.remove('disabled');
      }
    });
  }

  /* Inicializar ambos grupos de pills */
  initDayPills('diasDescansoGroup', 5);  /* días de descanso: máx 5 */
  initDayPills('diaProtocoloGroup', null); /* días de protocolo: sin límite */

  /* ─── VALIDACIÓN ─────────────────────────────────────────── */

  /**
   * Valida todos los campos del formulario.
   * Marca visualmente los que tienen error y retorna el estado global.
   * @returns {{ valido: boolean, primerError: string|null }}
   */
  function validarFormulario() {
    let valido      = true;
    let primerError = null;

    function marcar(fieldId, condError) {
      setError(fieldId, condError);
      if (condError && !primerError) primerError = fieldId;
      if (condError) valido = false;
    }

    const region          = document.getElementById('region').value;
    const planta          = document.getElementById('planta').value;
    const cantidad        = Number(document.getElementById('cantidadPersonal').value);
    const caracteristicas = document.getElementById('caracteristicas').value.trim();
    const tipoContr       = document.getElementById('tipoContratacion').value;
    const sexo            = document.getElementById('sexo').value;
    const edadMin         = Number(document.getElementById('edadMin').value);
    const edadMax         = Number(document.getElementById('edadMax').value);
    const rolarTurno      = document.getElementById('rolarTurno').value;
    const rolarEspec      = document.getElementById('rolarTurnoEspecificacion').value.trim();
    const epp             = document.getElementById('eppEspecial').value.trim();
    const diasDesc        = [...document.querySelectorAll('input[name="diasDescanso"]:checked')];
    const protocolo       = document.getElementById('protocoloIngreso').value;
    const diasProt        = [...document.querySelectorAll('input[name="diaProtocolo"]:checked')];

    /* Sección 1 */
    marcar('f-region',           !region);
    marcar('f-planta',           !planta);
    marcar('f-cantidadPersonal', !cantidad || cantidad < 1 || cantidad > 500);
    marcar('f-caracteristicas',  !caracteristicas || caracteristicas.length < 10);

    /* Sección 2 */
    marcar('f-tipoContratacion', !tipoContr);
    marcar('f-sexo',             !sexo);

    /* Validación de rango de edad */
    const edadInvalida =
      !edadMin || !edadMax ||
      edadMin < 16 || edadMin > 70 ||
      edadMax < 16 || edadMax > 70 ||
      edadMin >= edadMax;
    marcar('f-edadRango', edadInvalida);

    /* Sección 3 */
    marcar('f-rolarTurno', !rolarTurno);
    if (rolarTurno === 'Especifique') {
      marcar('f-rolarTurnoEspecificacion', !rolarEspec);
    }
    marcar('f-eppEspecial',   !epp || epp.length < 5);
    marcar('f-diasDescanso',  diasDesc.length < 1 || diasDesc.length > 5);

    /* Sección 4 */
    marcar('f-protocoloIngreso', !protocolo);
    marcar('f-diaProtocolo',     diasProt.length < 1);

    return { valido, primerError };
  }

  /* ─── ENVÍO DEL FORMULARIO ───────────────────────────────── */

  /**
   * Muestra / oculta los banners de feedback.
   * @param {'success'|'error'|null} type - null oculta ambos
   * @param {string} [msg] - Mensaje personalizado
   */
  function mostrarBanner(type, msg) {
    const bannerOk  = document.getElementById('banner-success');
    const bannerErr = document.getElementById('banner-error');

    bannerOk.classList.remove('visible');
    bannerErr.classList.remove('visible');

    if (type === 'success') {
      if (msg) document.getElementById('banner-success-msg').textContent = msg;
      bannerOk.classList.add('visible');
    } else if (type === 'error') {
      if (msg) document.getElementById('banner-error-msg').textContent = msg;
      bannerErr.classList.add('visible');
    }
  }

  /** Limpia el formulario y los estados visuales después de un envío exitoso */
  function limpiarFormulario() {
    document.getElementById('req-form').reset();

    /* Limpiar clases de error */
    document.querySelectorAll('.field.has-error').forEach(f => f.classList.remove('has-error'));

    /* Limpiar pills seleccionadas */
    document.querySelectorAll('.day-pill.sel').forEach(p => p.classList.remove('sel', 'disabled'));

    /* Restablecer estado del select de planta */
    const selPlanta = document.getElementById('planta');
    selPlanta.disabled  = true;
    selPlanta.innerHTML = '<option value="">Primero selecciona una región</option>';

    /* Cerrar campos condicionales */
    toggleCond('cond-rolar', false);

    /* Scroll al top */
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  /**
   * Handler del submit: valida, construye payload, envía, maneja respuesta.
   * Toda la comunicación con el servidor pasa por aquí.
   */
  async function enviarRequisicion(e) {
    e.preventDefault();
    mostrarBanner(null); /* ocultar banners previos */

    /* 1. Validar */
    const { valido, primerError } = validarFormulario();
    if (!valido) {
      /* Hacer scroll al primer campo con error */
      if (primerError) {
        const errorField = document.getElementById(primerError);
        if (errorField) {
          errorField.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      }
      return;
    }

    /* 2. Construir payload con los nombres de campo que espera el controlador */
    const payload = {
      id_region:             document.getElementById('region').value,
      id_planta:             document.getElementById('planta').value,
      cantidad_personal:     Number(document.getElementById('cantidadPersonal').value),
      caracteristicas:       document.getElementById('caracteristicas').value.trim(),
      tipo_contratacion:     document.getElementById('tipoContratacion').value,
      sexo:                  document.getElementById('sexo').value,
      edad_min:              Number(document.getElementById('edadMin').value),
      edad_max:              Number(document.getElementById('edadMax').value),
      rolar_turno:           document.getElementById('rolarTurno').value,
      rolar_especificacion:  document.getElementById('rolarTurnoEspecificacion').value.trim() || null,
      epp_especial:          document.getElementById('eppEspecial').value.trim(),
      dias_descanso:         [...document.querySelectorAll('input[name="diasDescanso"]:checked')].map(i => i.value),
      protocolo_ingreso:     document.getElementById('protocoloIngreso').value,
      dias_protocolo:        [...document.querySelectorAll('input[name="diaProtocolo"]:checked')].map(i => i.value),
    };

    /* 3. Deshabilitar botón durante el envío — previene doble submit */
    const btnSubmit     = document.getElementById('btn-submit');
    const btnSubmitText = document.getElementById('btn-submit-text');
    btnSubmit.disabled      = true;
    btnSubmitText.textContent = 'Enviando...';

    try {
      const res = await fetch('/capitalhumano/requisicion-personal', {
        method:  'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': getCsrfToken()
        },
        body: JSON.stringify(payload)
      });

      const data = await res.json();

      if (res.ok && data.ok) {
        /* 4a. Éxito */
        mostrarBanner('success', data.mensaje || 'Requisición enviada correctamente. El equipo de ACH la procesará a la brevedad.');
        limpiarFormulario();
      } else {
        /* 4b. Error controlado del servidor */
        mostrarBanner('error', data.mensaje || 'No se pudo registrar la requisición. Verifica los datos e intenta nuevamente.');
      }

    } catch (err) {
      /* 4c. Error de red / servidor no disponible */
      console.error('[ACH] Error de red al enviar requisición:', err);
      mostrarBanner('error', 'Error de conexión. Verifica tu red e intenta nuevamente.');
    } finally {
      /* Siempre rehabilitar el botón */
      btnSubmit.disabled      = false;
      btnSubmitText.innerHTML = '&#10003;&nbsp; Enviar Requisición';
    }
  }

  /* ─── INICIALIZACIÓN ─────────────────────────────────────── */
  document.addEventListener('DOMContentLoaded', function () {
    /* Cargar catálogos inmediatamente al abrir la vista */
    cargarCatalogos();

    /* Enlazar el handler de envío al formulario */
    document.getElementById('req-form').addEventListener('submit', enviarRequisicion);
  });

})();
</script>

</body>
</html>