<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Mis Reportes | Quality Bolca</title>
  <link rel="stylesheet" href="/styles/bots/estilos_inspectorReportes.css" />
  <meta name="csrf-token" content="<%= csrfToken %>">
</head>

<body>

  <!-- ========================================================
       HEADER
       ======================================================== -->
  <header class="ir-header">
    <div class="ir-header__brand">
      <img
        class="ir-header__logo"
        src="https://qualitybolca.com/assets/images/logo.png"
        alt="Quality Bolca"
        onerror="this.style.display='none'"
      />
    </div>
    <div class="ir-header__user">
      <span class="ir-header__avatar" aria-hidden="true"><%= usuarioInfo ? usuarioInfo.inicial : 'U' %></span>
      <span class="ir-header__username"><%= usuarioInfo ? usuarioInfo.nombreCorto : 'Usuario' %></span>
    </div>
  </header>


  <!-- ========================================================
       CONTENIDO PRINCIPAL
       ======================================================== -->
  <main class="ir-main">

    <!-- Titulo de pagina -->
    <div class="ir-page-header">
      <h1 class="ir-page-title">Mis Reportes Asignados</h1>
      <p class="ir-page-sub">Toca un reporte para iniciar la captura de datos</p>
    </div>

    <!-- Filtros rapidos -->
    <div class="ir-filters" role="group" aria-label="Filtrar reportes por estado">
      <button class="ir-filter-btn ir-filter-btn--active" data-filter="todos" aria-pressed="true">
        Todos
        <span class="ir-filter-count" id="count-todos">5</span>
      </button>
      <button class="ir-filter-btn" data-filter="pendiente" aria-pressed="false">
        Pendiente
        <span class="ir-filter-count" id="count-pendiente">3</span>
      </button>
      <button class="ir-filter-btn" data-filter="firmado" aria-pressed="false">
        Firmado
        <span class="ir-filter-count" id="count-firmado">1</span>
      </button>
      <button class="ir-filter-btn" data-filter="publicado" aria-pressed="false">
        Publicado
        <span class="ir-filter-count" id="count-publicado">1</span>
      </button>
    </div>

    <!-- Lista de cards -->
    <div class="ir-cards-list" id="cards-list" aria-label="Lista de reportes asignados">

      <!-- CARD 1 -->
      <article
        class="ir-card"
        data-estado="pendiente"
        role="button"
        tabindex="0"
        aria-label="Reporte REP-2026-041, Ford Motor Company, Bracket Soporte Trasero. Estado: Pendiente."
      >
        <div class="ir-card__header">
          <span class="ir-card__id">REP-2026-041</span>
          <span class="ir-badge ir-badge--pendiente">Pendiente</span>
        </div>
        <div class="ir-card__body">
          <div class="ir-card__row">
            <span class="ir-card__label">Cliente</span>
            <span class="ir-card__value">Ford Motor Company</span>
          </div>
          <div class="ir-card__row">
            <span class="ir-card__label">Parte a inspeccionar</span>
            <span class="ir-card__value ir-card__value--part">
              <span class="ir-part-number">48-6123-A</span>
              Bracket Soporte Trasero
            </span>
          </div>
          <div class="ir-card__row">
            <span class="ir-card__label">Cantidad total</span>
            <span class="ir-card__value">3,600 piezas</span>
          </div>
          <div class="ir-card__row">
            <span class="ir-card__label">Asignado el</span>
            <span class="ir-card__value">23/04/2026</span>
          </div>
        </div>
        <div class="ir-card__footer">
          <span class="ir-card__cta">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" aria-hidden="true">
              <path d="M12 2a3 3 0 0 1 3 3v7a3 3 0 0 1-6 0V5a3 3 0 0 1 3-3Z" />
              <path d="M19 10v2a7 7 0 0 1-14 0v-2" />
              <line x1="12" y1="19" x2="12" y2="22" />
              <line x1="8" y1="22" x2="16" y2="22" />
            </svg>
            Iniciar captura
          </span>
          <svg class="ir-card__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
            <polyline points="9 18 15 12 9 6" />
          </svg>
        </div>
      </article>

      <!-- CARD 2 -->
      <article
        class="ir-card"
        data-estado="firmado"
        role="button"
        tabindex="0"
        aria-label="Reporte REP-2026-039, Volkswagen de México, Clip Retención Lateral. Estado: Firmado."
      >
        <div class="ir-card__header">
          <span class="ir-card__id">REP-2026-039</span>
          <span class="ir-badge ir-badge--firmado">Firmado</span>
        </div>
        <div class="ir-card__body">
          <div class="ir-card__row">
            <span class="ir-card__label">Cliente</span>
            <span class="ir-card__value">Volkswagen de México</span>
          </div>
          <div class="ir-card__row">
            <span class="ir-card__label">Parte a inspeccionar</span>
            <span class="ir-card__value ir-card__value--part">
              <span class="ir-part-number">32-9001-C</span>
              Clip Retención Lateral
            </span>
          </div>
          <div class="ir-card__row">
            <span class="ir-card__label">Cantidad total</span>
            <span class="ir-card__value">2,150 piezas</span>
          </div>
          <div class="ir-card__row">
            <span class="ir-card__label">Asignado el</span>
            <span class="ir-card__value">22/04/2026</span>
          </div>
        </div>
        <div class="ir-card__footer">
          <span class="ir-card__cta">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" aria-hidden="true">
              <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
            Ver reporte
          </span>
          <svg class="ir-card__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
            <polyline points="9 18 15 12 9 6" />
          </svg>
        </div>
      </article>

      <!-- CARD 3 -->
      <article
        class="ir-card"
        data-estado="pendiente"
        role="button"
        tabindex="0"
        aria-label="Reporte REP-2026-037, General Motors, Soporte Plataforma Frontal. Estado: Pendiente."
      >
        <div class="ir-card__header">
          <span class="ir-card__id">REP-2026-037</span>
          <span class="ir-badge ir-badge--pendiente">Pendiente</span>
        </div>
        <div class="ir-card__body">
          <div class="ir-card__row">
            <span class="ir-card__label">Cliente</span>
            <span class="ir-card__value">General Motors</span>
          </div>
          <div class="ir-card__row">
            <span class="ir-card__label">Parte a inspeccionar</span>
            <span class="ir-card__value ir-card__value--part">
              <span class="ir-part-number">17-4452-B</span>
              Soporte Plataforma Frontal
            </span>
          </div>
          <div class="ir-card__row">
            <span class="ir-card__label">Cantidad total</span>
            <span class="ir-card__value">4,800 piezas</span>
          </div>
          <div class="ir-card__row">
            <span class="ir-card__label">Asignado el</span>
            <span class="ir-card__value">22/04/2026</span>
          </div>
        </div>
        <div class="ir-card__footer">
          <span class="ir-card__cta">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" aria-hidden="true">
              <path d="M12 2a3 3 0 0 1 3 3v7a3 3 0 0 1-6 0V5a3 3 0 0 1 3-3Z" />
              <path d="M19 10v2a7 7 0 0 1-14 0v-2" />
              <line x1="12" y1="19" x2="12" y2="22" />
              <line x1="8" y1="22" x2="16" y2="22" />
            </svg>
            Iniciar captura
          </span>
          <svg class="ir-card__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
            <polyline points="9 18 15 12 9 6" />
          </svg>
        </div>
      </article>

      <!-- CARD 4 -->
      <article
        class="ir-card"
        data-estado="publicado"
        role="button"
        tabindex="0"
        aria-label="Reporte REP-2026-035, Stellantis México, Refuerzo Puerta Trasera. Estado: Publicado."
      >
        <div class="ir-card__header">
          <span class="ir-card__id">REP-2026-035</span>
          <span class="ir-badge ir-badge--publicado">Publicado</span>
        </div>
        <div class="ir-card__body">
          <div class="ir-card__row">
            <span class="ir-card__label">Cliente</span>
            <span class="ir-card__value">Stellantis México</span>
          </div>
          <div class="ir-card__row">
            <span class="ir-card__label">Parte a inspeccionar</span>
            <span class="ir-card__value ir-card__value--part">
              <span class="ir-part-number">55-8801-D</span>
              Refuerzo Puerta Trasera
            </span>
          </div>
          <div class="ir-card__row">
            <span class="ir-card__label">Cantidad total</span>
            <span class="ir-card__value">1,980 piezas</span>
          </div>
          <div class="ir-card__row">
            <span class="ir-card__label">Asignado el</span>
            <span class="ir-card__value">21/04/2026</span>
          </div>
        </div>
        <div class="ir-card__footer">
          <span class="ir-card__cta">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" aria-hidden="true">
              <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
            Ver reporte
          </span>
          <svg class="ir-card__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
            <polyline points="9 18 15 12 9 6" />
          </svg>
        </div>
      </article>

      <!-- CARD 5 -->
      <article
        class="ir-card"
        data-estado="pendiente"
        role="button"
        tabindex="0"
        aria-label="Reporte REP-2026-033, Nissan Mexicana, Guía Cable Eléctrico. Estado: Pendiente."
      >
        <div class="ir-card__header">
          <span class="ir-card__id">REP-2026-033</span>
          <span class="ir-badge ir-badge--pendiente">Pendiente</span>
        </div>
        <div class="ir-card__body">
          <div class="ir-card__row">
            <span class="ir-card__label">Cliente</span>
            <span class="ir-card__value">Nissan Mexicana</span>
          </div>
          <div class="ir-card__row">
            <span class="ir-card__label">Parte a inspeccionar</span>
            <span class="ir-card__value ir-card__value--part">
              <span class="ir-part-number">61-3307-F</span>
              Guía Cable Eléctrico
            </span>
          </div>
          <div class="ir-card__row">
            <span class="ir-card__label">Cantidad total</span>
            <span class="ir-card__value">5,250 piezas</span>
          </div>
          <div class="ir-card__row">
            <span class="ir-card__label">Asignado el</span>
            <span class="ir-card__value">21/04/2026</span>
          </div>
        </div>
        <div class="ir-card__footer">
          <span class="ir-card__cta">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" aria-hidden="true">
              <path d="M12 2a3 3 0 0 1 3 3v7a3 3 0 0 1-6 0V5a3 3 0 0 1 3-3Z" />
              <path d="M19 10v2a7 7 0 0 1-14 0v-2" />
              <line x1="12" y1="19" x2="12" y2="22" />
              <line x1="8" y1="22" x2="16" y2="22" />
            </svg>
            Iniciar captura
          </span>
          <svg class="ir-card__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
            <polyline points="9 18 15 12 9 6" />
          </svg>
        </div>
      </article>

      <!-- Estado vacío (se muestra solo cuando el filtro no tiene resultados) -->
      <div class="ir-empty hidden" id="empty-state" role="status" aria-live="polite">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" width="48" height="48" aria-hidden="true">
          <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
        <p class="ir-empty__msg" id="empty-msg">No hay reportes con este estado.</p>
      </div>

    </div><!-- /ir-cards-list -->

  </main>


  <script src="/scripts/bots/scripts_inspectorReportes.js"></script>
</body>

</html>
